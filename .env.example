# ============================================================
# ComfortPlus ERP — 環境變數範本
# 複製此檔案為 .env.production 並填入實際值
#
#   cp .env.example .env.production
#
# ★ 標記為「必填」的項目部署前必須設定，否則系統無法啟動
# ============================================================

# ── 資料庫（必填）─────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"

# Docker Compose 內部使用（需與 DATABASE_URL 一致）
# ⚠️  這三個變數在 docker-compose 中為必填，未設定時容器拒絕啟動
# ⚠️  絕對不要使用預設值或簡單密碼（如 comfortplus123）
# 建議: openssl rand -base64 24
POSTGRES_USER="comfortplus_prod"
POSTGRES_PASSWORD="請換成強密碼-至少16字元含大小寫數字符號"
POSTGRES_DB="comfortplus_erp"

# ── NextAuth（必填）──────────────────────────────────────────
# 產生方式: openssl rand -base64 32
NEXTAUTH_SECRET="請換成至少32字元的隨機字串"
NEXTAUTH_URL="https://your-domain.com"

# ── 定時任務（必填）──────────────────────────────────────────
# 產生方式: openssl rand -base64 32
# 呼叫方式: curl -H "Authorization: Bearer $CRON_SECRET" https://your-domain.com/api/cron
# 注意: 必須 ≥32 字元，否則系統啟動時會回傳 500 錯誤
CRON_SECRET="請換成至少32字元的隨機字串"

# ── 敏感欄位加密（建議填）──────────────────────────────────
# 用於加密資料庫中的手機號碼、身份證等 PII 欄位
# 產生方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 未設定時欄位以明文儲存（開發環境可接受，生產環境必填）
ENCRYPTION_KEY=""

# ── AI / LLM（至少選一個）────────────────────────────────────
# 提供者: 'ollama' (本地GPU) 或 'anthropic' (雲端)
AI_PROVIDER="ollama"

# Ollama 本地（如用 Ollama）
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1:70b"

# Anthropic（如用 Claude）
# ANTHROPIC_API_KEY="sk-ant-..."

# ── LINE 通知（選填）─────────────────────────────────────────
# 申請: https://notify-bot.line.me/
# LINE_NOTIFY_TOKEN="your-line-notify-token"

# ── Email SMTP（選填，密碼重設功能需要）─────────────────────
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="ComfortPlus ERP <noreply@your-domain.com>"

# ── 版本標籤（部署用）────────────────────────────────────────
# 用於 Docker image tagging，方便版本回溯
# 建議用 git tag 或日期: APP_VERSION=$(git describe --tags --always)
APP_VERSION="latest"

# ── 備份設定（選填）──────────────────────────────────────────
# 本地備份保留天數（預設 30 天）
BACKUP_KEEP_DAYS=30

# AWS S3 異地備份（選填，不填則只備份到本地 /backups 目錄）
# S3_BUCKET="your-backup-bucket"
# AWS_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
# AWS_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
# AWS_DEFAULT_REGION="ap-northeast-1"
