# ============================================================
# ComfortPlus ERP — 環境變數範本
# 複製此檔案為 .env 並填入實際值
# ============================================================

# ── 資料庫（必填）─────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB_NAME"

# ── NextAuth（必填）───────────────────────────────────
NEXTAUTH_SECRET="至少32字元的隨機字串"
NEXTAUTH_URL="http://localhost:3001"

# ── AI / LLM（至少選一個）────────────────────────────
# 提供者: 'ollama' (本地GPU) 或 'anthropic' (雲端)
AI_PROVIDER="ollama"

# Ollama 本地（如用 Ollama）
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1:70b"

# Anthropic（如用 Claude）
# ANTHROPIC_API_KEY="sk-ant-..."

# ── 定時任務（建議設定）──────────────────────────────
# 排程呼叫: curl -H "Authorization: Bearer $CRON_SECRET" http://HOST/api/cron
CRON_SECRET="至少16字元的隨機字串"

# ── LINE 通知（選填）─────────────────────────────────
# 申請: https://notify-bot.line.me/
# LINE_NOTIFY_TOKEN="your-line-notify-token"

# ── Email SMTP（選填）────────────────────────────────
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="ComfortPlus ERP"
