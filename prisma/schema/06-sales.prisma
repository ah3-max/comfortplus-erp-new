model PriceList {
  id            String          @id @default(cuid())
  name          String
  customerType  CustomerType?
  customerId    String?
  channel       String?
  currency      String          @default("TWD")
  effectiveDate DateTime
  expiryDate    DateTime?
  isActive      Boolean         @default(true)
  region        String?
  version       Int             @default(1)
  approvedById  String?
  approvedAt    DateTime?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  customer      Customer?       @relation("CustomerPriceList", fields: [customerId], references: [id])
  items         PriceListItem[]
}

model PriceListItem {
  id               String    @id @default(cuid())
  priceListId      String
  productId        String
  standardPrice    Decimal   @db.Decimal(10, 2)
  specialPrice     Decimal?  @db.Decimal(10, 2)
  discountRate     Decimal?  @db.Decimal(5, 2)
  floorPrice       Decimal?  @db.Decimal(10, 2)
  requiresApproval Boolean   @default(false)
  notes            String?
  priceList        PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product          Product   @relation(fields: [productId], references: [id])
}

model Quotation {
  id                String              @id @default(cuid())
  quotationNo       String              @unique
  customerId        String
  customerContactId String?
  createdById       String
  status            QuotationStatus     @default(DRAFT)
  version           Int                 @default(1)
  validUntil        DateTime?
  totalAmount       Decimal             @db.Decimal(12, 2)
  currency          String              @default("TWD")
  taxType           String?
  paymentTerm       String?
  deliveryTerm      String?
  requiresApproval  Boolean             @default(false)
  approvalStatus    String?
  approvedById      String?
  attachment        String?
  previousVersionId String?
  versionNote       String?
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  createdBy         User                @relation(fields: [createdById], references: [id])
  customer          Customer            @relation(fields: [customerId], references: [id])
  approvals         QuotationApproval[]
  items             QuotationItem[]
  salesOrders       SalesOrder[]

  @@index([customerId, status])
  @@index([createdById, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

model QuotationItem {
  id              String    @id @default(cuid())
  quotationId     String
  productId       String
  productNameSnap String?
  skuSnap         String?
  specSnap        String?
  unit            String?
  quantity        Int
  unitPrice       Decimal   @db.Decimal(10, 2)
  discount        Decimal   @default(0) @db.Decimal(5, 2)
  subtotal        Decimal   @db.Decimal(12, 2)
  costSnap        Decimal?  @db.Decimal(10, 2)
  grossMargin     Decimal?  @db.Decimal(12, 2)
  grossMarginRate Decimal?  @db.Decimal(5, 2)
  notes           String?
  product         Product   @relation(fields: [productId], references: [id])
  quotation       Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model QuotationApproval {
  id            String    @id @default(cuid())
  quotationId   String
  approvalLevel Int       @default(1)
  approverRole  String    @default("SALES_MANAGER")
  triggerReason String?
  approverId    String?
  status        String    @default("PENDING")
  comment       String?
  decidedAt     DateTime?
  createdAt     DateTime  @default(now())
  approver      User?     @relation("QuotationApprover", fields: [approverId], references: [id])
  quotation     Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model SalesOrder {
  id                    String               @id @default(cuid())
  orderNo               String               @unique
  customerId            String
  customerContactId     String?
  quotationId           String?
  createdById           String
  status                OrderStatus          @default(DRAFT)
  orderType             OrderType            @default(B2B)
  orderSource           OrderSource          @default(SALES_INPUT)
  orderDate             DateTime             @default(now())
  requestedDeliveryDate DateTime?
  promisedDeliveryDate  DateTime?
  warehouseId           String?
  shippingMethod        String?
  paymentTerm           String?
  billingTerm           String?
  invoiceType           String?
  taxType               String?
  currency              String               @default("TWD")
  subtotal              Decimal              @db.Decimal(12, 2)
  discountAmount        Decimal              @default(0) @db.Decimal(12, 2)
  shippingFee           Decimal              @default(0) @db.Decimal(12, 2)
  taxAmount             Decimal              @default(0) @db.Decimal(12, 2)
  totalAmount           Decimal              @db.Decimal(12, 2)
  paidAmount            Decimal              @default(0) @db.Decimal(12, 2)
  costOfGoods           Decimal?             @db.Decimal(12, 2)
  grossProfit           Decimal?             @db.Decimal(12, 2)
  grossMarginPct        Decimal?             @db.Decimal(5, 2)
  deliveryCost          Decimal?             @db.Decimal(10, 2)
  netProfit             Decimal?             @db.Decimal(12, 2)
  isSplitOrder          Boolean              @default(false)
  splitFromOrderId      String?
  isUrgent              Boolean              @default(false)
  urgentReason          String?
  isSupportShipment     Boolean              @default(false)
  invoiceIds            String[]             @default([])
  notes                 String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  customerPoNo          String?
  idempotencyKey        String?              @unique
  arRecords             AccountsReceivable[] @relation("OrderAR")
  billingRequests       BillingRequest[]
  careIncidents         CareIncident[]
  channelOrders         ChannelOrder[]
  outboundRecords       OutboundRecord[]     @relation("OrderOutbound")
  payments              PaymentRecord[]
  recurringOrder        RecurringOrder?
  returnOrders          ReturnOrder[]
  salesInvoices         SalesInvoice[]       @relation("InvoiceFromOrder")
  createdBy             User                 @relation(fields: [createdById], references: [id])
  customer              Customer             @relation(fields: [customerId], references: [id])
  quotation             Quotation?           @relation(fields: [quotationId], references: [id])
  items                 SalesOrderItem[]
  shipments             Shipment[]
  warehousePickups      WarehousePickup[]

  @@index([customerId, status])
  @@index([customerId, orderDate(sort: Desc)])
  @@index([createdById, orderDate(sort: Desc)])
  @@index([status, orderDate(sort: Desc)])
  @@index([warehouseId, status])
}

model SalesOrderItem {
  id                   String     @id @default(cuid())
  orderId              String
  productId            String
  productNameSnap      String?
  skuSnap              String?
  specSnap             String?
  boxQty               Int?
  packQty              Int?
  pieceQty             Int?
  quantity             Int
  shippedQty           Int        @default(0)
  giftQty              Int        @default(0)
  unitPrice            Decimal    @db.Decimal(10, 2)
  discount             Decimal    @default(0) @db.Decimal(5, 2)
  subtotal             Decimal    @db.Decimal(12, 2)
  notes                String?
  batchNo              String?
  effectiveUnitCost    Decimal?   @db.Decimal(10, 4)
  grossMarginAmt       Decimal?   @db.Decimal(12, 2)
  grossMarginRate      Decimal?   @db.Decimal(5, 2)
  unitCostSnap         Decimal?   @db.Decimal(10, 4)
  warehouseStorageCost Decimal?   @db.Decimal(10, 4)
  warehouseStorageDays Int?
  order                SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product              Product    @relation(fields: [productId], references: [id])
}

model RecurringOrder {
  id               String               @id @default(cuid())
  customerId       String
  salesOrderId     String?              @unique
  frequency        String
  intervalDays     Int?
  startDate        DateTime
  endDate          DateTime?
  pauseFrom        DateTime?
  pauseTo          DateTime?
  nextDeliveryDate DateTime?
  autoCreateOrder  Boolean              @default(true)
  isActive         Boolean              @default(true)
  notes            String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  customer         Customer             @relation(fields: [customerId], references: [id])
  salesOrder       SalesOrder?          @relation(fields: [salesOrderId], references: [id])
  items            RecurringOrderItem[]
}

model RecurringOrderItem {
  id               String         @id @default(cuid())
  recurringOrderId String
  productId        String
  quantity         Int
  notes            String?
  product          Product        @relation(fields: [productId], references: [id])
  recurringOrder   RecurringOrder @relation(fields: [recurringOrderId], references: [id], onDelete: Cascade)
}
