model Customer {
  id                      String                    @id @default(cuid())
  code                    String                    @unique
  name                    String
  shortName               String?
  type                    CustomerType
  subType                 String?
  contactPerson           String?
  phone                   String?
  lineId                  String?
  email                   String?
  website                 String?
  address                 String?
  deliveryAddress         String?
  city                    String?
  region                  SalesRegion?
  country                 String?                   @default("TW")
  taxId                   String?
  invoiceTitle            String?
  invoiceAddress          String?
  paymentTerms            String?
  creditLimit             Decimal?                  @db.Decimal(12, 2)
  billingCycle            String?
  collectionMethod        String?
  isMonthly               Boolean                   @default(false)
  monthlySettleDay        Int?
  bankInfo                String?
  needsPO                 Boolean                   @default(false)
  needsStampedQuote       Boolean                   @default(false)
  needsInvoiceRequest     Boolean                   @default(false)
  hasContractPrice        Boolean                   @default(false)
  contractStartDate       DateTime?
  contractEndDate         DateTime?
  renewalRemindDate       DateTime?
  grade                   CustomerGrade?
  customerValueGrade      String?
  profitGrade             String?
  riskLevel               String?
  paymentStability        String?
  cooperationStability    String?
  devStatus               CustomerDevStatus         @default(POTENTIAL)
  source                  CustomerSource?
  salesRepId              String?
  winRate                 Int?
  estimatedMonthlyVolume  Decimal?                  @db.Decimal(12, 2)
  estimatedAnnualVolume   Decimal?                  @db.Decimal(12, 2)
  notes                   String?
  isActive                Boolean                   @default(true)
  isCorporateFoundation   Boolean                   @default(false)
  corporateFoundationName String?
  branchName              String?
  orgLevel                OrgLevel?
  bedCount                Int?
  lastContactDate         DateTime?
  nextFollowUpDate        DateTime?
  isFollowUp              Boolean                   @default(true)
  healthScore             Int?                      @default(100)
  healthLevel             String?
  healthUpdatedAt         DateTime?
  lastOrderDate           DateTime?
  avgOrderInterval        Int?
  lifetimeValue           Decimal?                  @db.Decimal(14, 2)
  churnReason             String?
  churnDate               DateTime?
  churnNote               String?
  creditUsed              Decimal?                  @default(0) @db.Decimal(12, 2)
  creditAvailable         Decimal?                  @db.Decimal(12, 2)
  creditUpdatedAt         DateTime?
  isCreditHold            Boolean                   @default(false)
  saturdayDelivery        Boolean                   @default(false)
  callBeforeDelivery      Boolean                   @default(false)
  floorCarry              Boolean                   @default(false)
  floorCarryNote          String?
  monthlyRestDays         String?
  deliveryTimeWindow      String?
  deliveryNote            String?
  isKeyAccount            Boolean                   @default(false)
  keyAccountMgrId         String?
  visitFrequencyDays      Int?
  relationshipScore       Int?
  keyAccountNote          String?
  keyAccountSince         DateTime?
  isBlacklist             Boolean                   @default(false)
  isWhitelist             Boolean                   @default(false)
  isHighRisk              Boolean                   @default(false)
  riskNote                String?
  isSupplyStopped         Boolean                   @default(false)
  supplyStopReason        String?
  supplyStopDate          DateTime?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  tourAutoAssigneeId      String?
  tourAutoSchedule        Boolean                   @default(false)
  accountsReceivable      AccountsReceivable[]
  afterSalesOrders        AfterSalesOrder[]         @relation("AfterSalesCustomer")
  billingRequests         BillingRequest[]
  businessEvents          BusinessEvent[]           @relation("CustomerBusinessEvents")
  callRecords             CallRecord[]
  careIncidents           CareIncident[]
  careSchedules           CareSchedule[]
  collectionLogs          CollectionLog[]           @relation("CustomerCollection")
  complaintRecords        ComplaintRecord[]
  contracts               Contract[]                @relation("ContractCustomer")
  creditDebitNotes        CreditDebitNote[]         @relation("CustomerCDN")
  keyAccountMgr           User?                     @relation("KeyAccountMgr", fields: [keyAccountMgrId], references: [id])
  salesRep                User?                     @relation("CustomerSalesRep", fields: [salesRepId], references: [id])
  tourAutoAssignee        User?                     @relation("TourAutoAssignee", fields: [tourAutoAssigneeId], references: [id])
  customerChangeLogs      CustomerChangeLog[]
  contacts                CustomerContact[]
  deliveryProfile         CustomerDeliveryProfile?
  demandForecast          CustomerDemandForecast?
  duplicateChecksA        CustomerDuplicateCheck[]  @relation("DupCheckA")
  duplicateChecksB        CustomerDuplicateCheck[]  @relation("DupCheckB")
  priceLevel              CustomerPriceLevel?       @relation("CustomerPriceLevel")
  requirements            CustomerRequirement?
  tagMaps                 CustomerTagMap[]
  usageProfile            CustomerUsageProfile?
  dispatchOrders          DispatchOrder[]           @relation("DispatchCustomer")
  eInvoices               EInvoice[]                @relation("CustomerEInvoice")
  followUpLogs            FollowUpLog[]
  institutionTours        InstitutionTour[]         @relation("TourCustomer")
  invoices                Invoice[]                 @relation("CustomerInvoice")
  meetingRecords          MeetingRecord[]           @relation("CustomerMeetingRecords")
  paymentRecords          PaymentRecord[]
  pickingOrders           PickingOrder[]            @relation("PickingCustomer")
  portalAccount           PortalAccount?
  priceLists              PriceList[]               @relation("CustomerPriceList")
  quotations              Quotation[]
  recallNotifications     RecallNotification[]
  reconciliations         ReconciliationStatement[]
  recurringOrders         RecurringOrder[]
  retailEvents            RetailEvent[]             @relation("RetailEventCustomer")
  returnOrders            ReturnOrder[]
  salesEvents             SalesEvent[]
  salesInvoices           SalesInvoice[]
  opportunities           SalesOpportunity[]
  salesOrders             SalesOrder[]
  salesRepChanges         SalesRepChange[]
  salesSchedules          SalesSchedule[]
  salesTasks              SalesTask[]
  sampleRecords           SampleRecord[]
  serviceRequests         ServiceRequest[]
  settlements             SettlementBatch[]         @relation("CustomerSettlements")
  specialPrices           SpecialPrice[]            @relation("CustomerSpecialPrices")
  visitRecords            VisitRecord[]
  warehousePickups        WarehousePickup[]

  @@index([salesRepId, isActive])
  @@index([devStatus, isActive])
  @@index([type, isActive])
  @@index([region, isActive])
  @@index([isKeyAccount, isActive])
  @@index([nextFollowUpDate])
}

model CustomerContact {
  id                   String           @id @default(cuid())
  customerId           String
  name                 String
  role                 ContactRole?
  title                String?
  department           String?
  mobile               String?
  phone                String?
  phoneExt             String?
  email                String?
  lineId               String?
  isPrimary            Boolean          @default(false)
  preferredContactTime ContactTimeSlot?
  notes                String?
  isActive             Boolean          @default(true)
  startDate            DateTime         @default(now())
  endDate              DateTime?
  changeReason         String?
  replacedById         String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  birthday             DateTime?
  birthdayNote         String?
  childrenInfo         String?
  favoriteThings       String?
  gender               String?
  hasChildren          Boolean?
  lifeEvents           String?
  personalNotes        String?
  preferences          String?
  taboos               String?
  customer             Customer         @relation(fields: [customerId], references: [id])
}

model CustomerUsageProfile {
  id                      String                    @id @default(cuid())
  customerId              String                    @unique
  profileDate             DateTime                  @default(now())
  totalBeds               Int?
  occupiedBeds            Int?
  vacantBeds              Int?
  residentCareNote        String?
  foreignCaregiverRatio   Float?
  foreignCaregiverCountry ForeignCaregiverCountry?
  managementQuality       ManagementQualityLevel?
  currentBrands           String?
  competitorBrands        String?
  brandSwitchFreq         BrandSwitchFrequency?
  easySwitchBrand         Boolean?
  procurementStyle        ProcurementDecisionStyle?
  dailyDiaperLargeQty     Int?
  dailyDiaperSmallQty     Int?
  dailyUnderpadsQty       Int?
  dailyWipesQty           Int?
  usesWipes               Boolean                   @default(false)
  monthlyDiaperLargeQty   Int?
  monthlyDiaperSmallQty   Int?
  monthlyUnderpadsQty     Int?
  monthlyWipesQty         Int?
  updatedById             String?
  updatedAt               DateTime                  @updatedAt
  createdAt               DateTime                  @default(now())
  customer                Customer                  @relation(fields: [customerId], references: [id])
}

model CustomerDemandForecast {
  id                     String              @id @default(cuid())
  customerId             String              @unique
  forecastMonth          DateTime            @default(now())
  dailyDiaperLargeQty    Int?
  dailyDiaperSmallQty    Int?
  dailyUnderpadsQty      Int?
  dailyWipesQty          Int?
  monthlyDiaperLargeQty  Int?
  monthlyDiaperSmallQty  Int?
  monthlyUnderpadsQty    Int?
  monthlyWipesQty        Int?
  orderFrequency         OrderFrequency?
  avgOrderQty            Int?
  nextExpectedOrderDate  DateTime?
  forecastConfidence     ForecastConfidence?
  notes                  String?
  avgDaysBetweenOrders   Int?
  avgCasesPerOrder       Decimal?            @db.Decimal(10, 2)
  last3OrdersTrend       String?
  predictedNextOrderDate DateTime?
  analyticsUpdatedAt     DateTime?
  updatedAt              DateTime            @updatedAt
  createdAt              DateTime            @default(now())
  customer               Customer            @relation(fields: [customerId], references: [id])
}

model CustomerDeliveryProfile {
  id                    String   @id @default(cuid())
  customerId            String   @unique
  deliveryAddress       String?
  unloadingLocation     String?
  unloadingFloor        Int?
  hasElevator           Boolean?
  needsCart             Boolean?
  hasReception          Boolean?
  receivingHours        String?
  suggestedDeliveryTime String?
  parkingNotes          String?
  routeNotes            String?
  receiverName          String?
  receiverPhone         String?
  deliveryNotes         String?
  photoUrls             Json?
  createdById           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  driverNotes           String?
  elevatorDimensions    String?
  elevatorHasElevator   Boolean?
  elevatorMaxWeight     Int?
  elevatorNotes         String?
  parkingFee            String?
  parkingSpot           String?
  customer              Customer @relation(fields: [customerId], references: [id])
}

model CustomerRequirement {
  id               String    @id @default(cuid())
  customerId       String    @unique
  bedCount         Int?
  residentCount    Int?
  currentBrand     String?
  currentSpec      String?
  monthlyUsage     Int?
  currentUnitPrice Decimal?  @db.Decimal(10, 2)
  procurementMode  String?
  isTrial          Boolean   @default(false)
  trialSentDate    DateTime?
  trialFeedback    String?
  decisionMaker    String?
  purchaseContact  String?
  financeContact   String?
  receivingContact String?
  notes            String?
  updatedAt        DateTime  @updatedAt
  customer         Customer  @relation(fields: [customerId], references: [id])
}

model CustomerChangeLog {
  id          String   @id @default(cuid())
  customerId  String
  changeType  String
  fieldName   String?
  beforeValue String?
  afterValue  String?
  reason      String?
  changedById String
  changedAt   DateTime @default(now())
  changedBy   User     @relation("CustomerChangeBy", fields: [changedById], references: [id])
  customer    Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, changeType, changedAt(sort: Desc)])
}

model CustomerDuplicateCheck {
  id            String    @id @default(cuid())
  customerAId   String
  customerBId   String
  matchType     String
  matchScore    Int
  status        String    @default("PENDING")
  resolvedById  String?
  resolvedAt    DateTime?
  mergeTargetId String?
  createdAt     DateTime  @default(now())
  customerA     Customer  @relation("DupCheckA", fields: [customerAId], references: [id])
  customerB     Customer  @relation("DupCheckB", fields: [customerBId], references: [id])

  @@unique([customerAId, customerBId])
}

model CustomerMergeLog {
  id              String   @id @default(cuid())
  survivorId      String
  mergedId        String
  mergedCode      String
  mergedName      String
  movedOrders     Int      @default(0)
  movedContacts   Int      @default(0)
  movedComplaints Int      @default(0)
  movedPayments   Int      @default(0)
  mergedById      String
  mergedAt        DateTime @default(now())
  notes           String?
}
