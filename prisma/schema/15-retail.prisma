model RetailBrand {
  id               String         @id @default(cuid())
  code             String         @unique
  name             String
  brandType        String         @default("OTHER")
  logoUrl          String?
  website          String?
  hqPhone          String?
  hqContact        String?
  buyerName        String?
  buyerTitle       String?
  buyerDept        String?
  buyerPhone       String?
  buyerEmail       String?
  buyerLine        String?
  purchaseMode     String?
  paymentTerms     String?
  creditDays       Int?
  deliveryLeadDays Int?
  minOrderQty      Int?
  minOrderNote     String?
  discountNote     String?
  listingFee       Decimal?       @db.Decimal(12, 2)
  annualFee        Decimal?       @db.Decimal(12, 2)
  contractExpiry   DateTime?
  contractNote     String?
  notes            String?
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  outlets          RetailOutlet[]
}

model RetailOutlet {
  id                  String                 @id @default(cuid())
  brandId             String
  channelId           String?
  outletCode          String?                @unique
  outletName          String
  address             String?
  city                String?
  region              String?
  phone               String?
  openHours           String?
  closedDays          String?
  storeManagerName    String?
  storeManagerPhone   String?
  storeManagerLine    String?
  salesRepId          String?
  salesRepName        String?
  backupContactName   String?
  backupContactPhone  String?
  displayShelfCount   Int?
  displayShelfSpec    String?
  displayRequirements String?
  facingCount         Int?
  shelfLocation       String?
  displayType         String?
  eventRequirements   String?
  promoCalendarNote   String?
  minOrderQtyPerEvent Int?
  placementZone       String?
  placementDetail     String?
  maxSkuCount         Int?
  maxUnitsPerSku      Int?
  maxPacksTotal       Int?
  currentSkuCount     Int?
  deliveryTimeWindow  String?
  deliveryDayOfWeek   String?
  logisticsNote       String?
  parkingInfo         String?
  loadingDockNote     String?
  commissionRate      Decimal?               @db.Decimal(5, 2)
  paymentTerms        String?
  settlementDay       Int?
  shelfRent           Decimal?               @db.Decimal(10, 2)
  displayFee          Decimal?               @db.Decimal(10, 2)
  isActive            Boolean                @default(true)
  notes               String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  displayRecords      RetailDisplayRecord[]
  events              RetailEvent[]
  groupBuys           RetailGroupBuy[]
  brand               RetailBrand            @relation(fields: [brandId], references: [id])
  channel             SalesChannel?          @relation(fields: [channelId], references: [id])
  salesPlans          RetailSalesPlan[]
  shipmentRecords     RetailShipmentRecord[]
}

model RetailSalesPlan {
  id             String       @id @default(cuid())
  outletId       String
  productId      String
  planMonth      DateTime     @db.Date
  targetQty      Int
  actualQty      Int          @default(0)
  targetAmount   Decimal?     @db.Decimal(12, 2)
  actualAmount   Decimal?     @db.Decimal(12, 2)
  promoType      String?
  promoDetail    String?
  promoStartDate DateTime?
  promoEndDate   DateTime?
  notes          String?
  createdAt      DateTime     @default(now())
  outlet         RetailOutlet @relation(fields: [outletId], references: [id])
  product        Product      @relation(fields: [productId], references: [id])
}

model RetailDisplayRecord {
  id             String       @id @default(cuid())
  outletId       String
  visitedById    String
  visitDate      DateTime
  displayOk      Boolean
  stockLevel     String?
  facingCount    Int?
  priceTagOk     Boolean?
  competitorNote String?
  photos         Json?
  notes          String?
  createdAt      DateTime     @default(now())
  outlet         RetailOutlet @relation(fields: [outletId], references: [id])
}

model RetailShipmentRecord {
  id          String       @id @default(cuid())
  outletId    String
  shipmentId  String?
  shipDate    DateTime
  items       Json
  totalAmount Decimal?     @db.Decimal(12, 2)
  invoiceNo   String?
  notes       String?
  createdAt   DateTime     @default(now())
  outlet      RetailOutlet @relation(fields: [outletId], references: [id])
}

model RetailEvent {
  id                    String          @id @default(cuid())
  outletId              String?
  channelId             String?
  customerId            String?
  eventType             String
  eventName             String
  eventStatus           String          @default("PLANNING")
  eventDate             DateTime
  endDate               DateTime?
  location              String?
  budget                Decimal?        @db.Decimal(12, 2)
  actualCost            Decimal?        @db.Decimal(12, 2)
  staffIds              String[]
  staffNote             String?
  setupRequirements     String?
  productRequirements   String?
  communicationNote     String?
  attendeeCount         Int?
  sampleQty             Int?
  ordersTaken           Int?
  leadsCollected        Int?
  revenueDuringEvent    Decimal?        @db.Decimal(12, 2)
  unitsSoldDuringEvent  Int?
  couponRedeemed        Int?
  newCustomersCollected Int?
  roi                   Decimal?        @db.Decimal(8, 2)
  targetAchievementPct  Decimal?        @db.Decimal(5, 2)
  performanceSummary    String?
  nextActionNote        String?
  photos                Json?
  notes                 String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  channel               SalesChannel?   @relation("ChannelRetailEvent", fields: [channelId], references: [id])
  customer              Customer?       @relation("RetailEventCustomer", fields: [customerId], references: [id])
  outlet                RetailOutlet?   @relation(fields: [outletId], references: [id])
  groupBuy              RetailGroupBuy?
}

model RetailGroupBuy {
  id               String        @id @default(cuid())
  eventId          String        @unique
  outletId         String?
  groupBuyTitle    String
  organizer        String?
  organizerPhone   String?
  organizerLine    String?
  platform         String?
  minQty           Int
  targetQty        Int?
  groupBuyPrice    Decimal       @db.Decimal(10, 2)
  originalPrice    Decimal?      @db.Decimal(10, 2)
  discountNote     String?
  includedProducts Json?
  openDate         DateTime
  closeDate        DateTime
  shipDate         DateTime?
  status           String        @default("OPEN")
  actualOrders     Int?
  actualQty        Int?
  actualRevenue    Decimal?      @db.Decimal(12, 2)
  fulfillmentNote  String?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  event            RetailEvent   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  outlet           RetailOutlet? @relation(fields: [outletId], references: [id])
}
