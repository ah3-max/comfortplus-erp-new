model ProductionOrder {
  id                   String                @id @default(cuid())
  productionNo         String                @unique
  purchaseOrderId      String
  factoryId            String
  status               ProductionStatus      @default(PENDING)
  orderQty             Int
  producedQty          Int?
  passedQty            Int?
  defectQty            Int?
  defectRate           Decimal?              @db.Decimal(5, 2)
  sampleSubmitDate     DateTime?
  sampleApproveDate    DateTime?
  productionStartDate  DateTime?
  productionEndDate    DateTime?
  inspectionDate       DateTime?
  shipmentDate         DateTime?
  packagingStatus      String?
  rawMaterialStatus    String?
  notes                String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  factoryIncidents     FactoryIncident[]
  materialRequisitions MaterialRequisition[]
  factory              Supplier              @relation("FactoryProduction", fields: [factoryId], references: [id])
  purchaseOrder        PurchaseOrder         @relation(fields: [purchaseOrderId], references: [id])
  productionReceipts   ProductionReceipt[]   @relation("ReceiptFromProduction")
  qualityChecks        QualityCheck[]
  seaFreights          SeaFreight[]
}

model SeaFreight {
  id                    String            @id @default(cuid())
  freightNo             String            @unique
  status                FreightStatus     @default(PENDING)
  customsStatus         CustomsStatus     @default(NOT_STARTED)
  productionOrderId     String?
  purchaseOrderId       String?
  shippingMode          String?
  incoterm              String?
  forwarder             String?
  customsBroker         String?
  containerType         String?
  containerNo           String?
  sealNo                String?
  bookingNo             String?
  blNo                  String?
  vesselName            String?
  voyageNo              String?
  shippingLine          String?
  portOfLoading         String?
  portOfDischarge       String?
  transshipPort         String?
  trackingUrl           String?
  delayReason           String?
  etd                   DateTime?
  eta                   DateTime?
  actualDeparture       DateTime?
  actualArrival         DateTime?
  factoryExitDate       DateTime?
  consolidationDate     DateTime?
  loadingDate           DateTime?
  customsDeclareDate    DateTime?
  customsReleasedDate   DateTime?
  customsCompletedDate  DateTime?
  devanningDate         DateTime?
  warehouseInDate       DateTime?
  customsDeclarationNo  String?
  invoiceNo             String?
  packingListNo         String?
  certificateOfOrigin   String?
  insuranceInfo         String?
  blAttachment          String?
  customsDocAttachment  String?
  palletCount           Int?
  boxCount              Int?
  weight                Decimal?          @db.Decimal(10, 3)
  volume                String?
  oceanFreight          Decimal?          @db.Decimal(12, 2)
  customsFee            Decimal?          @db.Decimal(12, 2)
  documentFee           Decimal?          @db.Decimal(12, 2)
  portCharge            Decimal?          @db.Decimal(12, 2)
  truckingFee           Decimal?          @db.Decimal(12, 2)
  insuranceFee          Decimal?          @db.Decimal(12, 2)
  storageFee            Decimal?          @db.Decimal(12, 2)
  otherFee              Decimal?          @db.Decimal(12, 2)
  totalCostTWD          Decimal?          @db.Decimal(12, 2)
  berthingTime          DateTime?
  dischargeTime         DateTime?
  containerPickupDate   DateTime?
  importerName          String?
  importerTaxId         String?
  hsCode                String?
  declaredValue         Decimal?          @db.Decimal(12, 2)
  dutyAmount            Decimal?          @db.Decimal(12, 2)
  vatAmount             Decimal?          @db.Decimal(12, 2)
  inspectionType        String?
  inspectionResult      String?
  documentsStatus       String?
  demurrageFee          Decimal?          @db.Decimal(12, 2)
  detentionFee          Decimal?          @db.Decimal(12, 2)
  packingListAttachment String?
  coaAttachment         String?
  originCertAttachment  String?
  notes                 String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  documentsJson         Json?
  importProjects        ImportProject[]   @relation("ImportProjectFreight")
  inboundRecords        InboundRecord[]
  productionOrder       ProductionOrder?  @relation(fields: [productionOrderId], references: [id])
  purchaseOrder         PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id])
  supplierInvoices      SupplierInvoice[]
}
