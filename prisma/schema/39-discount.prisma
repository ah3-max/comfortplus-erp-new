// ========== 折扣規則 ==========

model DiscountRule {
  id            String    @id @default(cuid())
  name          String
  ruleType      String    // SALES / PURCHASE
  discountType  String    // PERCENTAGE / FIXED_AMOUNT
  scope         String    @default("ALL") // ALL / CUSTOMER_TYPE / PRODUCT_CATEGORY / SPECIFIC
  scopeValue    String?   // CustomerType value / categoryId / customerId etc.
  minQty        Int?      // 最小數量門檻
  minAmount     Decimal?  @db.Decimal(12, 2) // 最低金額門檻
  discountValue Decimal   @db.Decimal(12, 2) // 折扣率(%)或折扣金額
  effectiveFrom DateTime? @db.Date
  effectiveTo   DateTime? @db.Date
  isActive      Boolean   @default(true)
  priority      Int       @default(0)
  notes         String?
  createdById   String
  createdBy     User      @relation("DiscountRuleCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([ruleType, isActive])
}
