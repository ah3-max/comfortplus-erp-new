model SalesChannel {
  id                String          @id @default(cuid())
  code              String          @unique
  name              String
  platform          ChannelPlatform
  shopUrl           String?
  commissionRate    Decimal?        @db.Decimal(5, 2)
  integrationMethod String?
  contactPerson     String?
  contactPhone      String?
  notes             String?
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  channelOrders     ChannelOrder[]
  retailEvents      RetailEvent[]   @relation("ChannelRetailEvent")
  retailOutlets     RetailOutlet[]
}

model ChannelOrder {
  id               String             @id @default(cuid())
  channelId        String
  channelOrderNo   String
  salesOrderId     String?
  buyerName        String?
  buyerPhone       String?
  buyerAddress     String?
  recipientName    String?
  recipientPhone   String?
  recipientAddress String?
  orderAmount      Decimal            @db.Decimal(12, 2)
  platformFee      Decimal?           @db.Decimal(12, 2)
  shippingFee      Decimal?           @db.Decimal(12, 2)
  netAmount        Decimal?           @db.Decimal(12, 2)
  status           ChannelOrderStatus @default(PENDING)
  paymentStatus    String?
  deliveryStatus   String?
  remittanceStatus String?
  orderedAt        DateTime
  notes            String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  channel          SalesChannel       @relation(fields: [channelId], references: [id])
  salesOrder       SalesOrder?        @relation(fields: [salesOrderId], references: [id])
  items            ChannelOrderItem[]
}

model ChannelOrderItem {
  id             String       @id @default(cuid())
  channelOrderId String
  productId      String?
  quantity       Int
  unitPrice      Decimal      @db.Decimal(10, 2)
  subtotal       Decimal      @db.Decimal(12, 2)
  platformSku    String?
  channelOrder   ChannelOrder @relation(fields: [channelOrderId], references: [id], onDelete: Cascade)
  product        Product?     @relation(fields: [productId], references: [id])
}

model ProductSkuMapping {
  id          String   @id @default(cuid())
  productId   String
  platform    String
  platformSku String
  channelId   String?
  notes       String?
  isActive    Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([platform, platformSku])
}
