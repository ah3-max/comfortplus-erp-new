model InternalUse {
  id            String            @id @default(cuid())
  useNo         String            @unique
  purpose       String
  warehouseId   String
  requestedById String
  approvedById  String?
  approvedAt    DateTime?
  issuedAt      DateTime?
  status        String            @default("DRAFT")
  totalCost     Decimal?          @db.Decimal(12, 2)
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  approvedBy    User?             @relation("InternalUseApproved", fields: [approvedById], references: [id])
  requestedBy   User              @relation("InternalUseRequested", fields: [requestedById], references: [id])
  warehouse     Warehouse         @relation("InternalUseWarehouse", fields: [warehouseId], references: [id])
  items         InternalUseItem[]

  @@index([status, createdAt(sort: Desc)])
}

model InternalUseItem {
  id        String        @id @default(cuid())
  useId     String
  productId String
  quantity  Int
  unitCost  Decimal?      @db.Decimal(10, 2)
  totalCost Decimal?      @db.Decimal(12, 2)
  lotId     String?
  notes     String?
  lot       InventoryLot? @relation("InternalUseItemLot", fields: [lotId], references: [id])
  product   Product       @relation("InternalUseItemProduct", fields: [productId], references: [id])
  use       InternalUse   @relation(fields: [useId], references: [id], onDelete: Cascade)
}

model DefectiveGoods {
  id              String        @id @default(cuid())
  defectNo        String        @unique
  source          String
  productId       String
  warehouseId     String
  quantity        Int
  discoveredAt    DateTime      @default(now())
  batchNo         String?
  lotId           String?
  defectType      String?
  severity        String        @default("MINOR")
  description     String?
  photoUrls       Json?         @default("[]")
  disposition     String?
  dispositionNote String?
  resolvedAt      DateTime?
  resolvedById    String?
  status          String        @default("PENDING")
  unitCost        Decimal?      @db.Decimal(10, 2)
  totalLoss       Decimal?      @db.Decimal(12, 2)
  qcId            String?
  scrapId         String?
  createdById     String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdBy       User          @relation("DefectiveGoodsCreated", fields: [createdById], references: [id])
  lot             InventoryLot? @relation("DefectiveGoodsLot", fields: [lotId], references: [id])
  product         Product       @relation("DefectiveGoodsProduct", fields: [productId], references: [id])
  qc              QualityCheck? @relation("DefectiveFromQC", fields: [qcId], references: [id])
  resolvedBy      User?         @relation("DefectiveGoodsResolver", fields: [resolvedById], references: [id])
  warehouse       Warehouse     @relation("DefectiveGoodsWarehouse", fields: [warehouseId], references: [id])

  @@index([status, createdAt(sort: Desc)])
  @@index([productId])
}
