model EmployeeProfile {
  id                  String    @id @default(cuid())
  userId              String    @unique
  nationalId          String?
  birthday            DateTime? @db.Date
  gender              String?
  maritalStatus       String?
  emergencyContact    String?
  emergencyPhone      String?
  bankAccount         String?
  bankName            String?
  laborInsuranceDate  DateTime? @db.Date
  healthInsuranceDate DateTime? @db.Date
  education           String?
  certifications      String?
  notes               String?
  updatedAt           DateTime  @updatedAt
  user                User      @relation("EmployeeProfile", fields: [userId], references: [id])
}

model Appointment {
  id             String   @id @default(cuid())
  userId         String
  effectiveDate  DateTime @db.Date
  type           String
  fromRole       String?
  toRole         String?
  fromDepartment String?
  toDepartment   String?
  fromTitle      String?
  toTitle        String?
  reason         String?
  approvedById   String?
  notes          String?
  createdAt      DateTime @default(now())
  user           User     @relation("AppointmentUser", fields: [userId], references: [id])

  @@index([userId, effectiveDate])
}

model Attendance {
  id        String    @id @default(cuid())
  userId    String
  date      DateTime  @db.Date
  clockIn   DateTime?
  clockOut  DateTime?
  status    String    @default("PRESENT")
  leaveType String?
  overtime  Decimal?  @db.Decimal(4, 1)
  notes     String?
  user      User      @relation("AttendanceUser", fields: [userId], references: [id])

  @@unique([userId, date])
}

model PayrollRecord {
  id              String    @id @default(cuid())
  userId          String
  periodYear      Int
  periodMonth     Int
  baseSalary      Decimal   @db.Decimal(12, 2)
  allowances      Decimal   @default(0) @db.Decimal(12, 2)
  overtimePay     Decimal   @default(0) @db.Decimal(12, 2)
  bonus           Decimal   @default(0) @db.Decimal(12, 2)
  deductions      Decimal   @default(0) @db.Decimal(12, 2)
  laborInsurance  Decimal   @default(0) @db.Decimal(12, 2)
  healthInsurance Decimal   @default(0) @db.Decimal(12, 2)
  tax             Decimal   @default(0) @db.Decimal(12, 2)
  netPay          Decimal   @db.Decimal(12, 2)
  status          String    @default("DRAFT")
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  user            User      @relation("PayrollUser", fields: [userId], references: [id])

  @@unique([userId, periodYear, periodMonth])
}
