model EInvoiceTurnkeyLog {
  id            String             @id @default(cuid())
  messageId     String             @unique
  messageType   TurnkeyMessageType
  version       String             @default("v41")
  eInvoiceId    String?
  invoiceNumber String
  sellerTaxId   String
  buyerTaxId    String
  fileName      String?
  xmlContent    String?
  status        TurnkeyStatus      @default(GENERATED)
  turnkeyStatus String?
  resultCode    String?
  resultMessage String?
  errorDetail   String?
  generatedAt   DateTime           @default(now())
  uploadedAt    DateTime?
  transmittedAt DateTime?
  resultAt      DateTime?
  createdById   String
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  createdBy     User               @relation("TurnkeyLogCreatedBy", fields: [createdById], references: [id])
  eInvoice      EInvoice?          @relation("TurnkeyLogEInvoice", fields: [eInvoiceId], references: [id])

  @@index([eInvoiceId])
  @@index([messageType, status])
  @@index([invoiceNumber])
  @@index([createdAt])
}
