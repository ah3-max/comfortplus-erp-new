model PickingOrder {
  id              String             @id @default(cuid())
  pickingNumber   String             @unique
  date            DateTime           @default(now())
  salesInvoiceId  String
  customerId      String
  handlerId       String
  warehouseId     String
  scheduledDate   DateTime?
  contactInfo     String?
  shippingAddress String?
  status          PickingStatus      @default(PENDING)
  createdById     String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  dispatchOrder   DispatchOrder?
  createdBy       User               @relation("PickingCreatedBy", fields: [createdById], references: [id])
  customer        Customer           @relation("PickingCustomer", fields: [customerId], references: [id])
  handler         User               @relation("PickingHandler", fields: [handlerId], references: [id])
  salesInvoice    SalesInvoice       @relation("PickingFromInvoice", fields: [salesInvoiceId], references: [id])
  warehouse       Warehouse          @relation("PickingWarehouse", fields: [warehouseId], references: [id])
  items           PickingOrderItem[]

  @@index([salesInvoiceId])
  @@index([status, date])
}

model PickingOrderItem {
  id             String       @id @default(cuid())
  pickingOrderId String
  productId      String
  productName    String
  specification  String?
  quantity       Decimal      @db.Decimal(10, 2)
  pickedQuantity Decimal      @default(0) @db.Decimal(10, 2)
  memo           String?
  pickingOrder   PickingOrder @relation(fields: [pickingOrderId], references: [id], onDelete: Cascade)
  product        Product      @relation("PickingItemProduct", fields: [productId], references: [id])

  @@index([pickingOrderId])
}

model DispatchOrder {
  id              String              @id @default(cuid())
  dispatchNumber  String              @unique
  date            DateTime            @default(now())
  pickingOrderId  String              @unique
  customerId      String
  handlerId       String
  warehouseId     String
  scheduledDate   DateTime?
  contactInfo     String?
  shippingAddress String?
  status          DispatchStatus      @default(PENDING)
  createdById     String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  driverName      String?
  driverPhone     String?
  vehicleNo       String?
  createdBy       User                @relation("DispatchCreatedBy", fields: [createdById], references: [id])
  customer        Customer            @relation("DispatchCustomer", fields: [customerId], references: [id])
  handler         User                @relation("DispatchHandler", fields: [handlerId], references: [id])
  pickingOrder    PickingOrder        @relation(fields: [pickingOrderId], references: [id])
  warehouse       Warehouse           @relation("DispatchWarehouse", fields: [warehouseId], references: [id])
  items           DispatchOrderItem[]

  @@index([pickingOrderId])
  @@index([status, date])
}

model DispatchOrderItem {
  id              String        @id @default(cuid())
  dispatchOrderId String
  productId       String
  productName     String
  specification   String?
  quantity        Decimal       @db.Decimal(10, 2)
  memo            String?
  dispatchOrder   DispatchOrder @relation(fields: [dispatchOrderId], references: [id], onDelete: Cascade)
  product         Product       @relation("DispatchItemProduct", fields: [productId], references: [id])

  @@index([dispatchOrderId])
}
