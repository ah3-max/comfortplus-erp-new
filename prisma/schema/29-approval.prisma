model ApprovalTemplate {
  id          String                 @id @default(cuid())
  name        String
  description String?
  module      String
  isActive    Boolean                @default(true)
  createdById String
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  requests    ApprovalRequest[]
  createdBy   User                   @relation("ApprovalTemplateCreatedBy", fields: [createdById], references: [id])
  steps       ApprovalTemplateStep[]
}

model ApprovalTemplateStep {
  id           String           @id @default(cuid())
  templateId   String
  stepOrder    Int
  stepName     String
  approverRole String
  isOptional   Boolean          @default(false)
  template     ApprovalTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model ApprovalRequest {
  id             String            @id @default(cuid())
  requestNo      String            @unique
  templateId     String?
  module         String
  entityId       String
  entityLabel    String
  status         String            @default("PENDING")
  currentStep    Int               @default(1)
  requestedById  String
  requestedAt    DateTime          @default(now())
  completedAt    DateTime?
  notes          String?
  updatedAt      DateTime          @updatedAt
  requestedBy    User              @relation("ApprovalRequestedBy", fields: [requestedById], references: [id])
  template       ApprovalTemplate? @relation(fields: [templateId], references: [id])
  steps          ApprovalStep[]
  expenseReports ExpenseReport[]   @relation("ExpenseApprovalRequest")
}

model ApprovalStep {
  id         String          @id @default(cuid())
  requestId  String
  stepOrder  Int
  stepName   String
  approverId String?
  status     String          @default("PENDING")
  action     String?
  comment    String?
  actedAt    DateTime?
  approver   User?           @relation("ApprovalStepApprover", fields: [approverId], references: [id])
  request    ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
}
