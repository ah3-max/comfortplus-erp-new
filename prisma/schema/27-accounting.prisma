model AccountingAccount {
  id            String             @id @default(cuid())
  code          String             @unique
  name          String
  type          String
  subType       String?
  normalBalance String             @default("DEBIT")
  parentCode    String?
  level         Int                @default(1)
  isActive      Boolean            @default(true)
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  lines         JournalEntryLine[]

  @@index([type, isActive])
  @@index([parentCode])
}

model FiscalPeriod {
  id             String          @id @default(cuid())
  periodCode     String          @unique
  periodType     String          @default("MONTHLY")
  year           Int
  month          Int?
  quarter        Int?
  startDate      DateTime        @db.Date
  endDate        DateTime        @db.Date
  status         PeriodStatus    @default(OPEN)
  closedAt       DateTime?
  closedById     String?
  lockedAt       DateTime?
  lockedById     String?
  notes          String?
  createdById    String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  expenseReports ExpenseReport[] @relation("ExpensePeriod")
  closedBy       User?           @relation("FiscalPeriodClosedBy", fields: [closedById], references: [id])
  createdBy      User            @relation("FiscalPeriodCreatedBy", fields: [createdById], references: [id])
  lockedBy       User?           @relation("FiscalPeriodLockedBy", fields: [lockedById], references: [id])
  journalEntries JournalEntry[]

  @@index([year, month])
  @@index([status])
}

model JournalEntry {
  id                 String                   @id @default(cuid())
  entryNo            String                   @unique
  entryDate          DateTime                 @db.Date
  description        String
  status             String                   @default("DRAFT")
  entryType          String                   @default("MANUAL")
  referenceType      String?
  referenceId        String?
  totalDebit         Decimal                  @db.Decimal(12, 2)
  totalCredit        Decimal                  @db.Decimal(12, 2)
  postedAt           DateTime?
  postedById         String?
  reversedById       String?
  reversedEntryId    String?
  periodId           String?
  notes              String?
  createdById        String
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  contractSchedules  ContractPaySchedule[]    @relation("ContractJournalEntry")
  expenseReport      ExpenseReport?           @relation("ExpenseJournal")
  assetDepreciations FixedAssetDepreciation[] @relation("AssetDepreciationJournal")
  createdBy          User                     @relation("JournalCreatedBy", fields: [createdById], references: [id])
  period             FiscalPeriod?            @relation(fields: [periodId], references: [id])
  postedBy           User?                    @relation("JournalPostedBy", fields: [postedById], references: [id])
  lines              JournalEntryLine[]

  @@index([entryDate, status])
  @@index([referenceType, referenceId])
}

model BankAccount {
  id             String            @id @default(cuid())
  accountName    String
  accountNo      String
  bankName       String
  bankCode       String?
  accountType    String            @default("CHECKING")
  currency       String            @default("TWD")
  openingBalance Decimal           @default(0) @db.Decimal(14, 2)
  currentBalance Decimal           @default(0) @db.Decimal(14, 2)
  creditLimit    Decimal?          @db.Decimal(14, 2)
  statementDay   Int?
  paymentDay     Int?
  isActive       Boolean           @default(true)
  notes          String?
  createdById    String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  createdBy      User              @relation("BankAccountCreatedBy", fields: [createdById], references: [id])
  transactions   BankTransaction[]

  @@index([accountType, isActive])
}

model BankTransaction {
  id              String      @id @default(cuid())
  bankAccountId   String
  txDate          DateTime    @db.Date
  description     String
  direction       String
  amount          Decimal     @db.Decimal(14, 2)
  balance         Decimal     @default(0) @db.Decimal(14, 2)
  referenceNo     String?
  category        String?
  paymentRecordId String?
  isReconciled    Boolean     @default(false)
  reconciledAt    DateTime?
  notes           String?
  createdById     String
  createdAt       DateTime    @default(now())
  bankAccount     BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  createdBy       User        @relation("BankTxCreatedBy", fields: [createdById], references: [id])

  @@index([bankAccountId, txDate])
  @@index([isReconciled])
}

model Cheque {
  id              String    @id @default(cuid())
  chequeNo        String
  chequeType      String
  bankName        String
  bankBranch      String?
  accountNo       String?
  amount          Decimal   @db.Decimal(14, 2)
  issueDate       DateTime  @db.Date
  dueDate         DateTime  @db.Date
  status          String    @default("HOLDING")
  partyName       String?
  partyId         String?
  partyType       String?
  bankAccountId   String?
  depositedAt     DateTime?
  clearedAt       DateTime?
  returnReason    String?
  paymentRecordId String?
  notes           String?
  createdById     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       User      @relation("ChequeCreatedBy", fields: [createdById], references: [id])

  @@index([chequeType, status])
  @@index([dueDate])
}

model VatFiling {
  id            String    @id @default(cuid())
  filingNo      String    @unique
  periodCode    String
  startDate     DateTime  @db.Date
  endDate       DateTime  @db.Date
  outputTaxBase Decimal   @default(0) @db.Decimal(14, 2)
  outputTax     Decimal   @default(0) @db.Decimal(14, 2)
  inputTaxBase  Decimal   @default(0) @db.Decimal(14, 2)
  inputTax      Decimal   @default(0) @db.Decimal(14, 2)
  netTax        Decimal   @default(0) @db.Decimal(14, 2)
  status        String    @default("DRAFT")
  filedAt       DateTime?
  paidAt        DateTime?
  taxAuthRef    String?
  notes         String?
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdBy     User      @relation("VatFilingCreatedBy", fields: [createdById], references: [id])

  @@index([status])
}

model InputTaxItem {
  id            String             @id @default(cuid())
  vendorName    String
  vendorTaxId   String?
  invoiceNo     String
  invoiceDate   DateTime           @db.Date
  subtotal      Decimal            @db.Decimal(12, 2)
  taxAmount     Decimal            @db.Decimal(12, 2)
  totalAmount   Decimal            @db.Decimal(12, 2)
  sourceType    InputTaxSourceType
  taxPeriod     String
  attachmentUrl String?
  apId          String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  ap            AccountsPayable?   @relation("APInputTax", fields: [apId], references: [id])

  @@index([taxPeriod])
  @@index([apId])
  @@index([invoiceNo])
}

model JournalEntryLine {
  id          String            @id @default(cuid())
  entryId     String
  accountId   String
  debit       Decimal           @default(0) @db.Decimal(12, 2)
  credit      Decimal           @default(0) @db.Decimal(12, 2)
  description String?
  lineNo      Int
  account     AccountingAccount @relation(fields: [accountId], references: [id])
  entry       JournalEntry      @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
  @@index([accountId])
}

model ExpenseCategoryMapping {
  id          String   @id @default(cuid())
  category    String   @unique
  accountCode String
  accountName String
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}
