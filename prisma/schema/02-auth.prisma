model User {
  id                        String                @id @default(cuid())
  employeeNo                String?               @unique
  email                     String                @unique
  name                      String
  avatar                    String?
  engName                   String?
  password                  String?
  role                      Role                  @default(SALES)
  departmentId              String?
  title                     String?
  mobile                    String?
  lineId                    String?
  hireDate                  DateTime?
  resignDate                DateTime?
  isActive                  Boolean               @default(true)
  notes                     String?
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  lineUserId                String?               @unique
  tokenVersion              Int                   @default(0)
  bankAccountName           String?
  bankAccountNo             String?
  bankCode                  String?
  afterSalesLogs            AfterSalesLog[]       @relation("AfterSalesLogCreatedBy")
  afterSalesAssigned        AfterSalesOrder[]     @relation("AfterSalesAssigned")
  afterSalesCreated         AfterSalesOrder[]     @relation("AfterSalesCreatedBy")
  announcementsCreated      Announcement[]        @relation("AnnouncementCreatedBy")
  appointments              Appointment[]         @relation("AppointmentUser")
  approvalRequestsMade      ApprovalRequest[]     @relation("ApprovalRequestedBy")
  approvalStepsAssigned     ApprovalStep[]        @relation("ApprovalStepApprover")
  approvalTemplatesCreated  ApprovalTemplate[]    @relation("ApprovalTemplateCreatedBy")
  assetsBorrowed            AssetLoan[]           @relation("AssetBorrower")
  assetLoansCreated         AssetLoan[]           @relation("AssetLoanCreatedBy")
  attendances               Attendance[]          @relation("AttendanceUser")
  auditLogs                 AuditLog[]
  bankAccountsCreated       BankAccount[]         @relation("BankAccountCreatedBy")
  bankTransactionsCreated   BankTransaction[]     @relation("BankTxCreatedBy")
  budgetsCreated            Budget[]              @relation("BudgetCreatedBy")
  createdBusinessEvents     BusinessEvent[]       @relation("BizEventCreatedBy")
  ownedBusinessEvents       BusinessEvent[]       @relation("BizEventOwner")
  callRecords               CallRecord[]          @relation("CalledBy")
  assignedIncidents         CareIncident[]        @relation("IncidentAssignedOwner")
  reportedIncidents         CareIncident[]        @relation("IncidentReportedBy")
  careSchedules             CareSchedule[]        @relation("CareScheduleSupervisor")
  cashFlowsCreated          CashFlowPlan[]        @relation("CashFlowCreatedBy")
  chequesCreated            Cheque[]              @relation("ChequeCreatedBy")
  collectionLogs            CollectionLog[]       @relation("CollectionCreatedBy")
  competitorPricesCreated   CompetitorPrice[]     @relation("CompetitorPriceCreatedBy")
  complaintLogs             ComplaintLog[]        @relation("ComplaintLoggedBy")
  supervisedComplaints      ComplaintRecord[]     @relation("ComplaintSupervisor")
  complaintRecords          ComplaintRecord[]     @relation("ComplaintReportedBy")
  contractsCreated          Contract[]            @relation("ContractCreatedBy")
  keyAccounts               Customer[]            @relation("KeyAccountMgr")
  managedCustomers          Customer[]            @relation("CustomerSalesRep")
  tourAutoAssigneeCustomers Customer[]            @relation("TourAutoAssignee")
  customerChangeLogs        CustomerChangeLog[]   @relation("CustomerChangeBy")
  dailyRemindersConfirmed   DailyReminderLog[]    @relation("ReminderConfirmer")
  dailyRemindersAsTarget    DailyReminderLog[]    @relation("ReminderTarget")
  defectiveGoodsCreated     DefectiveGoods[]      @relation("DefectiveGoodsCreated")
  defectiveGoodsResolved    DefectiveGoods[]      @relation("DefectiveGoodsResolver")
  managedDepts              Department[]          @relation("DeptManager")
  discountRulesCreated      DiscountRule[]        @relation("DiscountRuleCreatedBy")
  dispatchOrdersCreated     DispatchOrder[]       @relation("DispatchCreatedBy")
  dispatchOrdersHandled     DispatchOrder[]       @relation("DispatchHandler")
  documentVersions          DocumentVersion[]     @relation("DocVersionCreatedBy")
  eInvoicesCreated          EInvoice[]            @relation("EInvoiceCreatedBy")
  eInvoiceRangesCreated     EInvoiceNumberRange[] @relation("EInvoiceRangeCreatedBy")
  turnkeyLogsCreated        EInvoiceTurnkeyLog[]  @relation("TurnkeyLogCreatedBy")
  employeeProfile           EmployeeProfile?      @relation("EmployeeProfile")
  expensesApproved          ExpenseReport[]       @relation("ExpenseApprovedBy")
  expensesSubmitted         ExpenseReport[]       @relation("ExpenseSubmittedBy")
  exportLogs                ExportLog[]
  financeAttachments        FinanceAttachment[]   @relation("FinAttachUploadedBy")
  fiscalPeriodsClosed       FiscalPeriod[]        @relation("FiscalPeriodClosedBy")
  fiscalPeriodsCreated      FiscalPeriod[]        @relation("FiscalPeriodCreatedBy")
  fiscalPeriodsLocked       FiscalPeriod[]        @relation("FiscalPeriodLockedBy")
  fixedAssetsAssigned       FixedAsset[]          @relation("AssetAssignedTo")
  fixedAssetsCreated        FixedAsset[]          @relation("AssetCreatedBy")
  followUpLogs              FollowUpLog[]         @relation("FollowUpLogCreatedBy")
  importProjectsCreated     ImportProject[]       @relation("ImportProjectCreatedBy")
  incidentActionItems       IncidentActionItem[]  @relation("IncidentActionOwner")
  incidentAttachments       IncidentAttachment[]  @relation("IncidentAttachmentUploader")
  incidentAudioUploads      IncidentAudioRecord[] @relation("IncidentAudioUploader")
  incidentTrainings         IncidentTrainingLog[] @relation("IncidentTrainer")
  incidentVisitLogs         IncidentVisitLog[]    @relation("IncidentVisitLogBy")
  institutionToursAssigned  InstitutionTour[]     @relation("TourAssigned")
  institutionToursCreated   InstitutionTour[]     @relation("TourCreatedBy")
  internalUsesApproved      InternalUse[]         @relation("InternalUseApproved")
  internalUsesRequested     InternalUse[]         @relation("InternalUseRequested")
  journalEntriesCreated     JournalEntry[]        @relation("JournalCreatedBy")
  journalEntriesPosted      JournalEntry[]        @relation("JournalPostedBy")
  requisitionsCreated       MaterialRequisition[] @relation("RequisitionCreatedBy")
  requisitionsHandled       MaterialRequisition[] @relation("RequisitionHandler")
  meetingActionItems        MeetingActionItem[]   @relation("MeetingActionOwner")
  createdMeetingRecords     MeetingRecord[]       @relation("MeetingRecordCreatedBy")
  facilitatedMeetings       MeetingRecord[]       @relation("MeetingFacilitator")
  mrpSnapshots              MrpSnapshot[]         @relation("MrpSnapshotRunBy")
  notifications             Notification[]        @relation("NotificationUser")
  paymentsCreated           PaymentRecord[]       @relation("PaymentCreatedBy")
  payrollRecords            PayrollRecord[]       @relation("PayrollUser")
  pettyCashRecords          PettyCashRecord[]     @relation("PettyCashSubmitter")
  pickingOrdersCreated      PickingOrder[]        @relation("PickingCreatedBy")
  pickingOrdersHandled      PickingOrder[]        @relation("PickingHandler")
  priceTierUpdates          ProductPriceTier[]    @relation("PriceTierUpdatedBy")
  receiptsCreated           ProductionReceipt[]   @relation("ReceiptCreatedBy")
  receiptsHandled           ProductionReceipt[]   @relation("ReceiptHandler")
  managedPromoCalendars     PromoCalendar[]       @relation("PromoCalendarOwner")
  purchaseOrders            PurchaseOrder[]
  purchasePlansCreated      PurchasePlan[]        @relation("PurchasePlanCreatedBy")
  purchaseRequestsCreated   PurchaseRequest[]     @relation("PurchaseRequestCreatedBy")
  purchaseRequests          PurchaseRequest[]     @relation("PurchaseRequestHandler")
  purchaseReturnsCreated    PurchaseReturn[]      @relation("PurchaseReturnCreatedBy")
  quotations                Quotation[]
  quotationApprovals        QuotationApproval[]   @relation("QuotationApprover")
  recallNotifyBy            RecallNotification[]  @relation("RecallNotifiedBy")
  reviewedDailyReports      SalesDailyReport[]    @relation("DailyReportReviewer")
  dailyReports              SalesDailyReport[]    @relation("SalesRepDailyReport")
  salesEventsAssigned       SalesEvent[]          @relation("EventAssignedTo")
  salesEventsCreated        SalesEvent[]          @relation("EventCreatedBy")
  salesInvoicesCreated      SalesInvoice[]        @relation("SalesInvoiceCreatedBy")
  salesInvoicesHandler      SalesInvoice[]        @relation("SalesInvoiceHandler")
  salesInvoicesSales        SalesInvoice[]        @relation("SalesInvoiceSalesPerson")
  opportunities             SalesOpportunity[]    @relation("OpportunityOwner")
  salesOrders               SalesOrder[]
  salesRepChangesTo         SalesRepChange[]      @relation("NewRep")
  salesRepChangesFrom       SalesRepChange[]      @relation("PrevRep")
  salesSchedulesCreated     SalesSchedule[]       @relation("ScheduleCreatedBy")
  salesSchedules            SalesSchedule[]       @relation("ScheduleSalesRep")
  salesTargets              SalesTarget[]
  tasksAssigned             SalesTask[]           @relation("TaskAssignedTo")
  tasksCreated              SalesTask[]           @relation("TaskCreatedBy")
  sampleRecords             SampleRecord[]        @relation("SampleSentBy")
  serviceRequests           ServiceRequest[]      @relation("ServiceRequestAssigned")
  settlementsCreated        SettlementBatch[]     @relation("SettlementCreatedBy")
  shipments                 Shipment[]
  stockCounts               StockCount[]          @relation("StockCountCreatedBy")
  scrapsApproved            StockScrap[]          @relation("ScrapApprovedBy")
  scrapsCreated             StockScrap[]          @relation("ScrapCreatedBy")
  transfers                 StockTransfer[]       @relation("TransferRequestedBy")
  alertsAssigned            SystemAlert[]         @relation("AlertAssignedTo")
  uploadBatches             UploadBatch[]         @relation("UploadedByUser")
  department                Department?           @relation(fields: [departmentId], references: [id])
  moduleOverrides           UserModuleOverride[]  @relation("UserModuleOverrides")
  vatFilingsCreated         VatFiling[]           @relation("VatFilingCreatedBy")
  uploadedMedia             VisitMedia[]          @relation("MediaUploadedBy")
  visitRecords              VisitRecord[]         @relation("VisitedBy")
  pickups                   WarehousePickup[]     @relation("PickedBy")
  verifiedPickups           WarehousePickup[]     @relation("VerifiedBy")
  handoversFrom             WorkHandover[]        @relation("HandoverFrom")
  handoversTo               WorkHandover[]        @relation("HandoverTo")

  @@index([role, isActive])
  @@index([departmentId, isActive])
}

model Department {
  id        String       @id @default(cuid())
  code      String       @unique
  name      String
  parentId  String?
  managerId String?
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  manager   User?        @relation("DeptManager", fields: [managerId], references: [id])
  parent    Department?  @relation("DeptTree", fields: [parentId], references: [id])
  children  Department[] @relation("DeptTree")
  users     User[]
}

model RolePermission {
  id                    String   @id @default(cuid())
  roleName              String
  module                String
  canView               Boolean  @default(false)
  canCreate             Boolean  @default(false)
  canEdit               Boolean  @default(false)
  canDelete             Boolean  @default(false)
  canApprove            Boolean  @default(false)
  canExport             Boolean  @default(false)
  canViewCost           Boolean  @default(false)
  canViewMargin         Boolean  @default(false)
  canViewFinance        Boolean  @default(false)
  canCrossWarehouse     Boolean  @default(false)
  canCrossCompany       Boolean  @default(false)
  canViewSensitivePhoto Boolean  @default(false)
  canViewFloorPrice     Boolean  @default(false)
  dataScope             String   @default("ALL")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([roleName, module])
}

model ApprovalFlow {
  id               String   @id @default(cuid())
  flowName         String
  module           String
  triggerCondition String?
  level1Role       String?
  level2Role       String?
  level3Role       String?
  minAmount        Decimal? @db.Decimal(12, 2)
  maxAmount        Decimal? @db.Decimal(12, 2)
  isUrgent         Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
