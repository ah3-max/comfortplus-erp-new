model InstitutionTour {
  id               String    @id @default(cuid())
  tourNo           String    @unique
  assignedUserId   String
  customerId       String
  tourDate         DateTime  @db.Date
  plannedStartTime String?
  reminderMinutes  Int       @default(30)
  tourType         String    @default("ROUTINE_VISIT")
  purpose          String?
  status           String    @default("SCHEDULED")
  reminderSentAt   DateTime?
  departedAt       DateTime?
  arrivedAt        DateTime?
  completedAt      DateTime?
  reportResult     String?
  reportedAt       DateTime?
  createdById      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  assignedUser     User      @relation("TourAssigned", fields: [assignedUserId], references: [id])
  createdBy        User?     @relation("TourCreatedBy", fields: [createdById], references: [id])
  customer         Customer  @relation("TourCustomer", fields: [customerId], references: [id])

  @@index([tourDate, status])
  @@index([assignedUserId, tourDate])
  @@index([reminderSentAt, status])
}
