model Announcement {
  id          String    @id @default(cuid())
  title       String
  content     String
  category    String    @default("GENERAL")
  priority    String    @default("NORMAL")
  isPinned    Boolean   @default(false)
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  expiresAt   DateTime?
  targetRoles String[]  @default([])
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   User      @relation("AnnouncementCreatedBy", fields: [createdById], references: [id])

  @@index([isPublished, publishedAt(sort: Desc)])
}

model AssetLoan {
  id                 String    @id @default(cuid())
  assetName          String
  assetCode          String?
  category           String
  borrowerId         String
  borrowDate         DateTime  @db.Date
  expectedReturnDate DateTime? @db.Date
  actualReturnDate   DateTime? @db.Date
  status             String    @default("BORROWED")
  condition          String?
  notes              String?
  createdById        String
  createdAt          DateTime  @default(now())
  borrower           User      @relation("AssetBorrower", fields: [borrowerId], references: [id])
  createdBy          User      @relation("AssetLoanCreatedBy", fields: [createdById], references: [id])

  @@index([status, borrowerId])
}
