model ExpenseReport {
  id                String           @id @default(cuid())
  reportNo          String           @unique
  title             String
  department        String?
  status            String           @default("DRAFT")
  totalAmount       Decimal          @default(0) @db.Decimal(12, 2)
  currency          String           @default("TWD")
  notes             String?
  submittedById     String
  approvedById      String?
  submittedAt       DateTime?
  approvedAt        DateTime?
  paidAt            DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  approvalRequestId String?
  journalEntryId    String?          @unique
  periodId          String?
  items             ExpenseItem[]
  approvalRequest   ApprovalRequest? @relation("ExpenseApprovalRequest", fields: [approvalRequestId], references: [id])
  approvedBy        User?            @relation("ExpenseApprovedBy", fields: [approvedById], references: [id])
  journalEntry      JournalEntry?    @relation("ExpenseJournal", fields: [journalEntryId], references: [id])
  period            FiscalPeriod?    @relation("ExpensePeriod", fields: [periodId], references: [id])
  submittedBy       User             @relation("ExpenseSubmittedBy", fields: [submittedById], references: [id])

  @@index([status, submittedById])
}

model ExpenseItem {
  id            String        @id @default(cuid())
  reportId      String
  date          DateTime      @db.Date
  category      String
  description   String
  amount        Decimal       @db.Decimal(12, 2)
  receiptUrl    String?
  lineNo        Int
  glAccountCode String?
  report        ExpenseReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}
