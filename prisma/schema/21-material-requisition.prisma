model MaterialRequisition {
  id                String                    @id @default(cuid())
  requisitionNumber String                    @unique
  date              DateTime                  @default(now())
  productionOrderId String
  fromWarehouseId   String
  toWarehouseId     String
  handlerId         String
  status            RequisitionStatus         @default(DRAFT)
  notes             String?
  createdById       String
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  createdBy         User                      @relation("RequisitionCreatedBy", fields: [createdById], references: [id])
  fromWarehouse     Warehouse                 @relation("ReqFromWarehouse", fields: [fromWarehouseId], references: [id])
  handler           User                      @relation("RequisitionHandler", fields: [handlerId], references: [id])
  productionOrder   ProductionOrder           @relation(fields: [productionOrderId], references: [id])
  toWarehouse       Warehouse                 @relation("ReqToWarehouse", fields: [toWarehouseId], references: [id])
  items             MaterialRequisitionItem[]

  @@index([productionOrderId])
  @@index([status, date])
}

model MaterialRequisitionItem {
  id            String              @id @default(cuid())
  requisitionId String
  productId     String
  productName   String
  specification String?
  quantity      Decimal             @db.Decimal(10, 2)
  bomVersion    String?
  unit          String?
  serialNumber  String?
  memo          String?
  product       Product             @relation("RequisitionItemProduct", fields: [productId], references: [id])
  requisition   MaterialRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)

  @@index([requisitionId])
}

model ProductionReceipt {
  id                   String                  @id @default(cuid())
  receiptNumber        String                  @unique
  date                 DateTime                @default(now())
  factoryId            String
  receivingWarehouseId String
  handlerId            String
  productionOrderId    String?
  status               ReceiptStatus           @default(DRAFT)
  notes                String?
  createdById          String
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  createdBy            User                    @relation("ReceiptCreatedBy", fields: [createdById], references: [id])
  factory              Supplier                @relation("ReceiptFactory", fields: [factoryId], references: [id])
  handler              User                    @relation("ReceiptHandler", fields: [handlerId], references: [id])
  productionOrder      ProductionOrder?        @relation("ReceiptFromProduction", fields: [productionOrderId], references: [id])
  receivingWarehouse   Warehouse               @relation("ReceiptWarehouse", fields: [receivingWarehouseId], references: [id])
  items                ProductionReceiptItem[]

  @@index([productionOrderId])
  @@index([status, date])
}

model ProductionReceiptItem {
  id                 String            @id @default(cuid())
  receiptId          String
  productId          String
  productName        String
  specification      String?
  quantity           Decimal           @db.Decimal(10, 2)
  bomVersion         String?
  manufacturedItemId String?
  resourceInput      String?
  productionTime     Decimal?          @db.Decimal(8, 2)
  unit               String?
  memo               String?
  product            Product           @relation("ReceiptItemProduct", fields: [productId], references: [id])
  receipt            ProductionReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([receiptId])
}
