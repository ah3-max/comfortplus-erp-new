// ========== 零用金管理 ==========
// 適用：主管、行政助理、倉儲主管、業務等手邊持有零用金者

// ── 零用金帳戶（每人/每部門一個）──────────────────────────
model PettyCashFund {
  id          String   @id @default(cuid())
  name        String                       // 名稱（如：倉儲零用金、業務部零用金）
  holderName  String                       // 持有人姓名
  holderId    String?                      // 持有人 User.id
  department  String?                      // 所屬部門
  balance     Decimal  @db.Decimal(12, 2) @default(0)  // 目前餘額
  limit       Decimal  @db.Decimal(12, 2) @default(5000) // 零用金上限
  currency    String   @default("TWD")
  isActive    Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  records     PettyCashRecord[]

  @@index([holderId])
}

// ── 零用金支出記錄 ──────────────────────────────────────────
model PettyCashRecord {
  id          String         @id @default(cuid())
  fundId      String
  fund        PettyCashFund  @relation(fields: [fundId], references: [id])
  recordNo    String         @unique   // 流水號 PC-202403-001

  date        DateTime       @db.Date  // 支出日期
  category    String
  // 類別：FUEL(油費) / MEAL(餐費) / TRANSPORT(交通) / OFFICE(辦公用品)
  //       MAINTENANCE(保養維修) / POSTAGE(郵資) / CLEANING(清潔) / OTHER(其他)

  description String         // 支出說明（業務自填）
  amount      Decimal        @db.Decimal(12, 2)
  vendor      String?        // 商家/收款方
  receiptNo   String?        // 發票/收據號碼

  // 憑證照片（JSON: [{ url, label }]）
  // 現場拍照先上傳，後補正式憑證
  receiptPhotos Json?        // 收據/憑證照片
  hasReceipt   Boolean       @default(false) // 是否已有正式憑證

  // 狀態流程
  status      String         @default("PENDING")
  // PENDING → 待財務確認
  // CONFIRMED → 財務已確認
  // REJECTED → 財務退回
  // REIMBURSED → 已補款

  notes       String?        // 額外備注

  // 審核
  reviewedById String?       // 財務審核人 User.id
  reviewedAt   DateTime?
  reviewNote   String?       // 退回原因/審核意見

  submittedById String
  submittedBy   User         @relation("PettyCashSubmitter", fields: [submittedById], references: [id])

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([fundId, date])
  @@index([status])
  @@index([submittedById])
}
