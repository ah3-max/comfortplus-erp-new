model PettyCashFund {
  id         String            @id @default(cuid())
  name       String
  holderName String
  holderId   String?
  department String?
  balance    Decimal           @default(0) @db.Decimal(12, 2)
  limit      Decimal           @default(5000) @db.Decimal(12, 2)
  currency   String            @default("TWD")
  isActive   Boolean           @default(true)
  notes      String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  records    PettyCashRecord[]

  @@index([holderId])
}

model PettyCashRecord {
  id            String        @id @default(cuid())
  fundId        String
  recordNo      String        @unique
  date          DateTime      @db.Date
  category      String
  description   String
  amount        Decimal       @db.Decimal(12, 2)
  vendor        String?
  receiptNo     String?
  receiptPhotos Json?
  hasReceipt    Boolean       @default(false)
  status        String        @default("PENDING")
  notes         String?
  reviewedById  String?
  reviewedAt    DateTime?
  reviewNote    String?
  submittedById String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  fund          PettyCashFund @relation(fields: [fundId], references: [id])
  submittedBy   User          @relation("PettyCashSubmitter", fields: [submittedById], references: [id])

  @@index([fundId, date])
  @@index([status])
  @@index([submittedById])
}
