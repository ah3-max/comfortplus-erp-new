model CompetitorPrice {
  id            String   @id @default(cuid())
  recordDate    DateTime @db.Date
  channel       String
  competitor    String
  productName   String
  sku           String?
  spec          String?
  unitPrice     Decimal  @db.Decimal(10, 2)
  originalPrice Decimal? @db.Decimal(10, 2)
  promoNote     String?
  isOnShelf     Boolean  @default(true)
  sourceUrl     String?
  notes         String?
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     User     @relation("CompetitorPriceCreatedBy", fields: [createdById], references: [id])

  @@index([recordDate, channel, competitor])
  @@index([competitor, productName])
}
