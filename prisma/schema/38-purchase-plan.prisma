model PurchasePlan {
  id          String             @id @default(cuid())
  planNo      String             @unique
  planYear    Int
  planMonth   Int
  status      String             @default("DRAFT")
  totalBudget Decimal            @default(0) @db.Decimal(12, 2)
  notes       String?
  createdById String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  createdBy   User               @relation("PurchasePlanCreatedBy", fields: [createdById], references: [id])
  items       PurchasePlanItem[]

  @@unique([planYear, planMonth])
}

model PurchasePlanItem {
  id           String       @id @default(cuid())
  planId       String
  productId    String
  requiredQty  Int
  unitPrice    Decimal?     @db.Decimal(12, 2)
  supplierId   String?
  expectedDate DateTime?    @db.Date
  notes        String?
  lineNo       Int
  plan         PurchasePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  product      Product      @relation("PurchasePlanProduct", fields: [productId], references: [id])
  supplier     Supplier?    @relation("PurchasePlanSupplier", fields: [supplierId], references: [id])
}
