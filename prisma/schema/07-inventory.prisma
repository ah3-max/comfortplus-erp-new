model Inventory {
  id            String            @id @default(cuid())
  productId     String
  warehouse     String            @default("MAIN")
  category      InventoryCategory @default(FINISHED_GOODS)
  quantity      Int               @default(0)
  availableQty  Int               @default(0)
  reservedQty   Int               @default(0)
  lockedQty     Int               @default(0)
  damagedQty    Int               @default(0)
  safetyStock   Int               @default(0)
  lastCountDate DateTime?
  updatedAt     DateTime          @updatedAt
  version       Int               @default(0)
  product       Product           @relation(fields: [productId], references: [id])

  @@unique([productId, warehouse, category])
}

model InventoryTransaction {
  id            String             @id @default(cuid())
  productId     String
  warehouse     String             @default("MAIN")
  lotId         String?
  category      InventoryCategory?
  type          TransactionType
  quantity      Int
  beforeQty     Int?
  afterQty      Int?
  referenceType String?
  referenceId   String?
  notes         String?
  createdById   String?
  createdAt     DateTime           @default(now())
  lot           InventoryLot?      @relation(fields: [lotId], references: [id])

  @@index([productId, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
  @@index([referenceType, referenceId])
}

model Warehouse {
  id                   String                    @id @default(cuid())
  code                 String                    @unique
  name                 String
  warehouseType        String?
  address              String?
  managerId            String?
  phone                String?
  notes                String?
  isActive             Boolean                   @default(true)
  totalCapacityBoxes   Int?
  totalCapacityPallets Int?
  currentOccupancy     Int?                      @default(0)
  monthlyRent          Decimal?                  @db.Decimal(12, 2)
  rentDueDay           Int?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  defectiveGoods       DefectiveGoods[]          @relation("DefectiveGoodsWarehouse")
  dispatchOrdersWH     DispatchOrder[]           @relation("DispatchWarehouse")
  inboundRecords       InboundRecord[]
  internalUses         InternalUse[]             @relation("InternalUseWarehouse")
  lots                 InventoryLot[]
  requisitionsFrom     MaterialRequisition[]     @relation("ReqFromWarehouse")
  requisitionsTo       MaterialRequisition[]     @relation("ReqToWarehouse")
  outboundRecords      OutboundRecord[]
  pickingOrdersWH      PickingOrder[]            @relation("PickingWarehouse")
  receiptsReceiving    ProductionReceipt[]       @relation("ReceiptWarehouse")
  purchaseRequestWH    PurchaseRequest[]         @relation("PurchaseRequestWarehouse")
  salesInvoices        SalesInvoice[]            @relation("SalesInvoiceWarehouse")
  stockCounts          StockCount[]
  countSchedules       StockCountSchedule[]
  scrapRecords         StockScrap[]
  transfersFrom        StockTransfer[]           @relation("TransferFrom")
  transfersTo          StockTransfer[]           @relation("TransferTo")
  locations            WarehouseLocation[]
  pickingStrategy      WarehousePickingStrategy?
  wmsZones             WmsZone[]                 @relation("WmsZoneWarehouse")
}

model WarehouseLocation {
  id                      String    @id @default(cuid())
  warehouseId             String
  zone                    String
  rack                    String?
  position                String?
  locationType            String?
  maxCapacity             Int?
  capacityUnit            String?   @default("BOX")
  currentOccupancy        Int?      @default(0)
  occupancyRate           Decimal?  @db.Decimal(5, 2)
  isTemperatureControlled Boolean   @default(false)
  isQuarantineZone        Boolean   @default(false)
  allowedCategories       String[]  @default([])
  isActive                Boolean   @default(true)
  notes                   String?
  warehouse               Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([warehouseId, zone, rack, position])
}

model InboundRecord {
  id              String        @id @default(cuid())
  inboundNo       String        @unique
  warehouseId     String
  sourceType      String
  sourceId        String?
  seaFreightId    String?
  returnOrderId   String?
  arrivalDate     DateTime      @default(now())
  checkedById     String?
  qcResult        String?
  putawayStatus   String        @default("PENDING")
  receivingPhotos Json?
  temperatureC    Decimal?      @db.Decimal(4, 1)
  humidityPct     Decimal?      @db.Decimal(4, 1)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  items           InboundItem[]
  returnOrder     ReturnOrder?  @relation(fields: [returnOrderId], references: [id])
  seaFreight      SeaFreight?   @relation(fields: [seaFreightId], references: [id])
  warehouse       Warehouse     @relation(fields: [warehouseId], references: [id])
}

model InboundItem {
  id              String        @id @default(cuid())
  inboundId       String
  productId       String
  batchNo         String?
  quantity        Int
  expectedQty     Int?
  damageQty       Int           @default(0)
  shortQty        Int           @default(0)
  cartonCondition String?
  receivingNote   String?
  locationCode    String?
  notes           String?
  inbound         InboundRecord @relation(fields: [inboundId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id])
}

model OutboundRecord {
  id            String         @id @default(cuid())
  outboundNo    String         @unique
  warehouseId   String
  orderId       String?
  shipDate      DateTime?
  pickingStatus String         @default("PENDING")
  packingStatus String         @default("PENDING")
  shippedStatus String         @default("PENDING")
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  items         OutboundItem[]
  order         SalesOrder?    @relation("OrderOutbound", fields: [orderId], references: [id])
  warehouse     Warehouse      @relation(fields: [warehouseId], references: [id])
}

model OutboundItem {
  id           String         @id @default(cuid())
  outboundId   String
  productId    String
  batchNo      String?
  quantity     Int
  pickedQty    Int            @default(0)
  locationCode String?
  notes        String?
  outbound     OutboundRecord @relation(fields: [outboundId], references: [id], onDelete: Cascade)
  product      Product        @relation(fields: [productId], references: [id])
}

model InventoryLot {
  id                   String                 @id @default(cuid())
  lotNo                String                 @unique
  productId            String
  warehouseId          String
  location             String?
  category             InventoryCategory      @default(FINISHED_GOODS)
  status               StockStatus            @default(AVAILABLE)
  quantity             Int                    @default(0)
  lockedQty            Int                    @default(0)
  manufactureDate      DateTime?
  expiryDate           DateTime?
  inboundDate          DateTime?
  daysToExpiry         Int?
  isNearExpiry         Boolean                @default(false)
  isExpired            Boolean                @default(false)
  quarantineReason     String?
  quarantineDate       DateTime?
  releaseDate          DateTime?
  releasedById         String?
  sourceFactory        String?
  supplierId           String?
  factoryLotNo         String?
  purchaseOrderId      String?
  notes                String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  batchCostAllocations BatchCostAllocation[]
  defectiveGoods       DefectiveGoods[]       @relation("DefectiveGoodsLot")
  internalUseItems     InternalUseItem[]      @relation("InternalUseItemLot")
  product              Product                @relation(fields: [productId], references: [id])
  purchaseOrder        PurchaseOrder?         @relation(fields: [purchaseOrderId], references: [id])
  supplier             Supplier?              @relation("LotSupplier", fields: [supplierId], references: [id])
  warehouse            Warehouse              @relation(fields: [warehouseId], references: [id])
  transactions         InventoryTransaction[]
  countItems           StockCountItem[]
  scrapRecords         StockScrap[]
  transferItems        StockTransferItem[]
}

model StockTransfer {
  id              String              @id @default(cuid())
  transferNo      String              @unique
  fromWarehouseId String
  toWarehouseId   String
  status          TransferStatus      @default(PENDING)
  requestedById   String
  transferDate    DateTime?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  fromWarehouse   Warehouse           @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  requestedBy     User                @relation("TransferRequestedBy", fields: [requestedById], references: [id])
  toWarehouse     Warehouse           @relation("TransferTo", fields: [toWarehouseId], references: [id])
  items           StockTransferItem[]
}

model StockTransferItem {
  id         String        @id @default(cuid())
  transferId String
  productId  String
  lotId      String?
  quantity   Int
  lot        InventoryLot? @relation(fields: [lotId], references: [id])
  product    Product       @relation(fields: [productId], references: [id])
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
}

model StockCount {
  id             String           @id @default(cuid())
  countNo        String           @unique
  warehouseId    String
  status         StockCountStatus @default(DRAFT)
  countDate      DateTime?
  countType      String           @default("FULL")
  plannedDate    DateTime?
  assignedToId   String?
  reviewedById   String?
  reviewedAt     DateTime?
  totalItems     Int?
  totalVariance  Int?
  varianceRate   Decimal?         @db.Decimal(5, 2)
  varianceAmount Decimal?         @db.Decimal(12, 2)
  photos         Json?
  attachments    Json?
  notes          String?
  createdById    String
  completedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  createdBy      User             @relation("StockCountCreatedBy", fields: [createdById], references: [id])
  warehouse      Warehouse        @relation(fields: [warehouseId], references: [id])
  items          StockCountItem[]
}

model StockCountItem {
  id               String        @id @default(cuid())
  countId          String
  productId        String
  lotId            String?
  systemQty        Int
  countedQty       Int           @default(0)
  variance         Int           @default(0)
  varianceReason   String?
  varianceAmount   Decimal?      @db.Decimal(12, 2)
  adjustmentAction String?
  adjustedById     String?
  adjustedAt       DateTime?
  locationCode     String?
  photoUrl         String?
  notes            String?
  count            StockCount    @relation(fields: [countId], references: [id], onDelete: Cascade)
  lot              InventoryLot? @relation(fields: [lotId], references: [id])
  product          Product       @relation(fields: [productId], references: [id])
}

model StockScrap {
  id                String        @id @default(cuid())
  scrapNo           String        @unique
  productId         String
  warehouseId       String
  lotId             String?
  quantity          Int
  reason            String?
  scrapCategory     String?
  status            String        @default("PENDING")
  requestedAt       DateTime      @default(now())
  approvedAt        DateTime?
  executedAt        DateTime?
  rejectedReason    String?
  unitCost          Decimal?      @db.Decimal(10, 2)
  totalLoss         Decimal?      @db.Decimal(12, 2)
  photos            Json?
  batchNo           String?
  qcId              String?
  returnOrderId     String?
  factoryIncidentId String?
  responsibility    String?
  approvedById      String?
  scrapDate         DateTime      @default(now())
  createdById       String?
  notes             String?
  createdAt         DateTime      @default(now())
  approvedBy        User?         @relation("ScrapApprovedBy", fields: [approvedById], references: [id])
  createdBy         User?         @relation("ScrapCreatedBy", fields: [createdById], references: [id])
  lot               InventoryLot? @relation(fields: [lotId], references: [id])
  product           Product       @relation(fields: [productId], references: [id])
  warehouse         Warehouse     @relation(fields: [warehouseId], references: [id])
}

model WarehousePickingStrategy {
  id              String    @id @default(cuid())
  warehouseId     String    @unique
  strategy        String    @default("FEFO")
  expiryAlertDays Int       @default(90)
  autoQuarantine  Boolean   @default(true)
  notes           String?
  updatedAt       DateTime  @updatedAt
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])
}

model StockCountSchedule {
  id               String    @id @default(cuid())
  warehouseId      String
  frequency        String
  scheduledDay     Int?
  nextScheduleDate DateTime
  assignedToId     String?
  isActive         Boolean   @default(true)
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  warehouse        Warehouse @relation(fields: [warehouseId], references: [id])
}

model ProductRecall {
  id                    String               @id @default(cuid())
  recallNo              String               @unique
  productId             String
  batchNos              String[]
  factoryId             String?
  recallReason          String
  severity              String               @default("HIGH")
  discoveredDate        DateTime
  affectedCustomerCount Int?
  affectedQuantity      Int?
  affectedShipmentIds   String[]
  status                String               @default("INITIATED")
  notificationDate      DateTime?
  collectionDeadline    DateTime?
  completedDate         DateTime?
  handleMethod          String?
  estimatedLoss         Decimal?             @db.Decimal(12, 2)
  actualLoss            Decimal?             @db.Decimal(12, 2)
  notes                 String?
  createdById           String
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  product               Product              @relation(fields: [productId], references: [id])
  notifications         RecallNotification[]
}

model RecallNotification {
  id               String        @id @default(cuid())
  recallId         String
  customerId       String
  shipmentId       String?
  affectedQty      Int
  notifiedAt       DateTime?
  notifyMethod     String?
  notifiedById     String?
  collectionStatus String        @default("PENDING")
  collectedQty     Int?
  collectedDate    DateTime?
  replacementSent  Boolean       @default(false)
  creditAmount     Decimal?      @db.Decimal(12, 2)
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  customer         Customer      @relation(fields: [customerId], references: [id])
  notifiedBy       User?         @relation("RecallNotifiedBy", fields: [notifiedById], references: [id])
  recall           ProductRecall @relation(fields: [recallId], references: [id])
}

model WarehousePickup {
  id                String                @id @default(cuid())
  pickupNo          String                @unique
  warehouse         String                @default("MARKETING")
  pickedById        String
  pickupDate        DateTime              @default(now())
  purpose           PickupPurpose         @default(DELIVERY)
  customerId        String?
  orderId           String?
  status            PickupStatus          @default(PENDING_PHOTO)
  photos            Json                  @default("[]")
  photoCount        Int                   @default(0)
  verifiedById      String?
  verifiedAt        DateTime?
  verifyNotes       String?
  inventoryDeducted Boolean               @default(false)
  notes             String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  customer          Customer?             @relation(fields: [customerId], references: [id])
  order             SalesOrder?           @relation(fields: [orderId], references: [id])
  pickedBy          User                  @relation("PickedBy", fields: [pickedById], references: [id])
  verifiedBy        User?                 @relation("VerifiedBy", fields: [verifiedById], references: [id])
  items             WarehousePickupItem[]

  @@index([pickedById])
  @@index([status])
  @@index([warehouse])
}

model WarehousePickupItem {
  id        String          @id @default(cuid())
  pickupId  String
  productId String
  quantity  Int
  unit      String          @default("包")
  photoUrl  String?
  notes     String?
  pickup    WarehousePickup @relation(fields: [pickupId], references: [id])
  product   Product         @relation(fields: [productId], references: [id])

  @@index([pickupId])
}
