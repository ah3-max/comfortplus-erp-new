// ========== 庫存管理 ==========
model Inventory {
  id          String            @id @default(cuid())
  productId   String
  product     Product           @relation(fields: [productId], references: [id])
  warehouse   String            @default("MAIN")
  category      InventoryCategory @default(FINISHED_GOODS)
  quantity      Int               @default(0)    // 帳面數量
  availableQty  Int               @default(0)    // 可用數量 = quantity - lockedQty - reservedQty
  reservedQty   Int               @default(0)    // 訂單預留
  lockedQty     Int               @default(0)    // 鎖定（盤點/凍結）
  damagedQty    Int               @default(0)    // 不良品數量
  safetyStock   Int               @default(0)
  lastCountDate DateTime?                        // 最近盤點日
  updatedAt     DateTime          @updatedAt

  @@unique([productId, warehouse, category])
}

model InventoryTransaction {
  id            String             @id @default(cuid())
  productId     String
  warehouse     String             @default("MAIN")
  lotId         String?
  lot           InventoryLot?      @relation(fields: [lotId], references: [id])
  category      InventoryCategory?
  type          TransactionType
  quantity      Int
  beforeQty     Int?
  afterQty      Int?
  referenceType String?
  referenceId   String?
  notes         String?
  createdById   String?
  createdAt     DateTime           @default(now())
}

// ========== 倉庫管理 ==========
model Warehouse {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  warehouseType String? // OWNED / THIRD_PARTY / TEMP
  address      String?
  managerId    String?  // 負責人
  phone        String?
  notes        String?
  isActive     Boolean  @default(true)
  totalCapacityBoxes    Int?
  totalCapacityPallets  Int?
  currentOccupancy      Int?      @default(0)
  monthlyRent           Decimal?  @db.Decimal(12, 2)
  rentDueDay            Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lots              InventoryLot[]
  locations         WarehouseLocation[]
  transfersFrom     StockTransfer[] @relation("TransferFrom")
  transfersTo       StockTransfer[] @relation("TransferTo")
  stockCounts       StockCount[]
  scrapRecords      StockScrap[]
  inboundRecords    InboundRecord[]
  outboundRecords   OutboundRecord[]
  pickingStrategy   WarehousePickingStrategy?
  countSchedules    StockCountSchedule[]
}

// ========== 倉位管理 ==========
model WarehouseLocation {
  id            String    @id @default(cuid())
  warehouseId   String
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id])
  zone          String    // 區域 A/B/C
  rack          String?   // 貨架
  position      String?   // 儲位
  locationType  String?   // PALLET / SHELF / FLOOR / COLD
  maxCapacity   Int?      // 最大容量
  capacityUnit  String?   @default("BOX")
  currentOccupancy       Int?      @default(0)
  occupancyRate          Decimal?  @db.Decimal(5, 2)
  isTemperatureControlled Boolean  @default(false)
  isQuarantineZone       Boolean   @default(false)
  allowedCategories      String[]  @default([])
  isActive      Boolean   @default(true)
  notes         String?

  @@unique([warehouseId, zone, rack, position])
}

// ========== 入庫管理 ==========
model InboundRecord {
  id            String      @id @default(cuid())
  inboundNo     String      @unique
  warehouseId   String
  warehouse     Warehouse   @relation(fields: [warehouseId], references: [id])
  sourceType    String      // PURCHASE / RETURN / TRANSFER / SEA_FREIGHT
  sourceId      String?     // 關聯單號 ID（通用）
  seaFreightId  String?
  seaFreight    SeaFreight? @relation(fields: [seaFreightId], references: [id])
  returnOrderId String?
  returnOrder   ReturnOrder? @relation(fields: [returnOrderId], references: [id])
  arrivalDate   DateTime @default(now())
  checkedById   String?
  qcResult      String?  // PASS / FAIL / CONDITIONAL
  putawayStatus String   @default("PENDING") // PENDING / IN_PROGRESS / COMPLETED
  receivingPhotos  Json?
  temperatureC     Decimal?  @db.Decimal(4, 1)
  humidityPct      Decimal?  @db.Decimal(4, 1)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items         InboundItem[]
}

model InboundItem {
  id          String        @id @default(cuid())
  inboundId   String
  inbound     InboundRecord @relation(fields: [inboundId], references: [id], onDelete: Cascade)
  productId   String
  product     Product       @relation(fields: [productId], references: [id])
  batchNo     String?
  quantity    Int
  expectedQty    Int?
  damageQty      Int           @default(0)
  shortQty       Int           @default(0)
  cartonCondition String?
  receivingNote   String?
  locationCode String?     // 上架庫位
  notes       String?
}

// ========== 出庫管理 ==========
model OutboundRecord {
  id            String      @id @default(cuid())
  outboundNo    String      @unique
  warehouseId   String
  warehouse     Warehouse   @relation(fields: [warehouseId], references: [id])
  orderId       String?
  order         SalesOrder? @relation("OrderOutbound", fields: [orderId], references: [id])
  shipDate      DateTime?
  pickingStatus String   @default("PENDING") // PENDING / PICKING / PICKED
  packingStatus String   @default("PENDING") // PENDING / PACKING / PACKED
  shippedStatus String   @default("PENDING") // PENDING / SHIPPED
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items         OutboundItem[]
}

model OutboundItem {
  id          String         @id @default(cuid())
  outboundId  String
  outbound    OutboundRecord @relation(fields: [outboundId], references: [id], onDelete: Cascade)
  productId   String
  product     Product        @relation(fields: [productId], references: [id])
  batchNo     String?
  quantity    Int
  pickedQty   Int            @default(0)
  locationCode String?       // 揀貨庫位
  notes       String?
}

// ========== 批號管理 ==========
model InventoryLot {
  id              String            @id @default(cuid())
  lotNo           String            @unique
  productId       String
  product         Product           @relation(fields: [productId], references: [id])
  warehouseId     String
  warehouse       Warehouse         @relation(fields: [warehouseId], references: [id])
  location        String?           // 庫位代碼，e.g. "A-01-03"
  category        InventoryCategory @default(FINISHED_GOODS)
  status          StockStatus       @default(AVAILABLE)
  quantity        Int               @default(0)
  lockedQty       Int               @default(0)
  manufactureDate DateTime?
  expiryDate      DateTime?
  inboundDate     DateTime?
  daysToExpiry    Int?
  isNearExpiry    Boolean           @default(false)
  isExpired       Boolean           @default(false)
  quarantineReason String?
  quarantineDate   DateTime?
  releaseDate      DateTime?
  releasedById     String?
  sourceFactory   String?           // 工廠名稱文字快照（舊欄位保留）
  supplierId      String?           // 生產廠商 FK（推薦使用）
  supplier        Supplier?         @relation("LotSupplier", fields: [supplierId], references: [id])
  factoryLotNo    String?           // 工廠原始批號（用於召回追溯）
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?    @relation(fields: [purchaseOrderId], references: [id])
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  transactions  InventoryTransaction[]
  transferItems StockTransferItem[]
  countItems    StockCountItem[]
  scrapRecords  StockScrap[]
  batchCostAllocations BatchCostAllocation[]
}

// ========== 調撥管理 ==========
model StockTransfer {
  id              String         @id @default(cuid())
  transferNo      String         @unique
  fromWarehouseId String
  fromWarehouse   Warehouse      @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String
  toWarehouse     Warehouse      @relation("TransferTo", fields: [toWarehouseId], references: [id])
  status          TransferStatus @default(PENDING)
  requestedById   String
  requestedBy     User           @relation("TransferRequestedBy", fields: [requestedById], references: [id])
  transferDate    DateTime?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  items StockTransferItem[]
}

model StockTransferItem {
  id         String        @id @default(cuid())
  transferId String
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId  String
  product    Product       @relation(fields: [productId], references: [id])
  lotId      String?
  lot        InventoryLot? @relation(fields: [lotId], references: [id])
  quantity   Int
}

// ========== 盤點管理 ==========
model StockCount {
  id          String           @id @default(cuid())
  countNo     String           @unique
  warehouseId String
  warehouse   Warehouse        @relation(fields: [warehouseId], references: [id])
  status      StockCountStatus @default(DRAFT)
  countDate   DateTime?
  countType   String           @default("FULL")
  plannedDate DateTime?
  assignedToId String?
  reviewedById String?
  reviewedAt   DateTime?
  totalItems   Int?
  totalVariance Int?
  varianceRate  Decimal?       @db.Decimal(5, 2)
  varianceAmount Decimal?      @db.Decimal(12, 2)
  photos       Json?
  attachments  Json?
  notes       String?
  createdById String
  createdBy   User             @relation("StockCountCreatedBy", fields: [createdById], references: [id])
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  items StockCountItem[]
}

model StockCountItem {
  id         String        @id @default(cuid())
  countId    String
  count      StockCount    @relation(fields: [countId], references: [id], onDelete: Cascade)
  productId  String
  product    Product       @relation(fields: [productId], references: [id])
  lotId      String?
  lot        InventoryLot? @relation(fields: [lotId], references: [id])
  systemQty  Int
  countedQty Int           @default(0)
  variance   Int           @default(0)
  varianceReason  String?
  varianceAmount  Decimal?      @db.Decimal(12, 2)
  adjustmentAction String?
  adjustedById    String?
  adjustedAt      DateTime?
  locationCode    String?
  photoUrl        String?
  notes      String?
}

// ========== 報廢管理 ==========
model StockScrap {
  id           String        @id @default(cuid())
  scrapNo      String        @unique
  productId    String
  product      Product       @relation(fields: [productId], references: [id])
  warehouseId  String
  warehouse    Warehouse     @relation(fields: [warehouseId], references: [id])
  lotId        String?
  lot          InventoryLot? @relation(fields: [lotId], references: [id])
  quantity     Int
  reason       String?
  scrapCategory String?
  status       String        @default("PENDING")
  requestedAt  DateTime      @default(now())
  approvedAt   DateTime?
  executedAt   DateTime?
  rejectedReason String?
  unitCost     Decimal?      @db.Decimal(10, 2)
  totalLoss    Decimal?      @db.Decimal(12, 2)
  photos       Json?
  batchNo      String?
  qcId         String?
  returnOrderId String?
  factoryIncidentId String?
  responsibility String?
  approvedById String?
  approvedBy   User?         @relation("ScrapApprovedBy", fields: [approvedById], references: [id])
  scrapDate    DateTime      @default(now())
  createdById  String?
  createdBy    User?         @relation("ScrapCreatedBy", fields: [createdById], references: [id])
  notes        String?
  createdAt    DateTime      @default(now())
}

// ========== 揀貨策略 ==========
model WarehousePickingStrategy {
  id              String   @id @default(cuid())
  warehouseId     String   @unique
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])
  strategy        String   @default("FEFO")
  expiryAlertDays Int      @default(90)
  autoQuarantine  Boolean  @default(true)
  notes           String?
  updatedAt       DateTime @updatedAt
}

// ========== 盤點排程 ==========
model StockCountSchedule {
  id              String   @id @default(cuid())
  warehouseId     String
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])
  frequency       String
  scheduledDay    Int?
  nextScheduleDate DateTime
  assignedToId    String?
  isActive        Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ========== 產品召回 ==========
model ProductRecall {
  id                    String   @id @default(cuid())
  recallNo              String   @unique
  productId             String
  product               Product  @relation(fields: [productId], references: [id])
  batchNos              String[]
  factoryId             String?
  recallReason          String
  severity              String   @default("HIGH")
  discoveredDate        DateTime
  affectedCustomerCount Int?
  affectedQuantity      Int?
  affectedShipmentIds   String[]
  status                String   @default("INITIATED")
  notificationDate      DateTime?
  collectionDeadline    DateTime?
  completedDate         DateTime?
  handleMethod          String?
  estimatedLoss         Decimal? @db.Decimal(12, 2)
  actualLoss            Decimal? @db.Decimal(12, 2)
  notes                 String?
  createdById           String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  notifications         RecallNotification[]
}

// ========== 召回通知 ==========
model RecallNotification {
  id              String        @id @default(cuid())
  recallId        String
  recall          ProductRecall @relation(fields: [recallId], references: [id])
  customerId      String
  customer        Customer      @relation(fields: [customerId], references: [id])
  shipmentId      String?
  affectedQty     Int
  notifiedAt      DateTime?
  notifyMethod    String?
  notifiedById    String?
  notifiedBy      User?         @relation("RecallNotifiedBy", fields: [notifiedById], references: [id])
  collectionStatus String       @default("PENDING")
  collectedQty    Int?
  collectedDate   DateTime?
  replacementSent Boolean       @default(false)
  creditAmount    Decimal?      @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ========== 行銷倉取貨記錄 ==========
// 業務從中和行銷倉 or 龜山大倉取貨時需拍照存檔
// 辦公室助理核對後扣庫存
model WarehousePickup {
  id              String          @id @default(cuid())
  pickupNo        String          @unique
  warehouse       String          @default("MARKETING")  // MARKETING=中和行銷倉, MAIN=龜山大倉
  pickedById      String                                  // 取貨人（業務）
  pickedBy        User            @relation("PickedBy", fields: [pickedById], references: [id])
  pickupDate      DateTime        @default(now())

  // 用途
  purpose         PickupPurpose   @default(DELIVERY)      // 送貨/樣品/其他
  customerId      String?                                  // 送貨對象（可選）
  customer        Customer?       @relation(fields: [customerId], references: [id])
  orderId         String?                                  // 關聯訂單（可選）
  order           SalesOrder?     @relation(fields: [orderId], references: [id])

  // 狀態
  status          PickupStatus    @default(PENDING_PHOTO)  // 流程狀態
  photos          Json            @default("[]")           // 取貨拍照 [{url, uploadedAt, note}]
  photoCount      Int             @default(0)

  // 核對
  verifiedById    String?                                  // 核對人（辦公室助理）
  verifiedBy      User?           @relation("VerifiedBy", fields: [verifiedById], references: [id])
  verifiedAt      DateTime?
  verifyNotes     String?                                  // 核對備註（數量對/品項對/異常）
  inventoryDeducted Boolean       @default(false)          // 是否已扣庫存

  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  items           WarehousePickupItem[]

  @@index([pickedById])
  @@index([status])
  @@index([warehouse])
}

model WarehousePickupItem {
  id          String           @id @default(cuid())
  pickupId    String
  pickup      WarehousePickup  @relation(fields: [pickupId], references: [id])
  productId   String
  product     Product          @relation(fields: [productId], references: [id])
  quantity    Int                                          // 取貨數量
  unit        String           @default("包")
  photoUrl    String?                                      // 單品拍照（可選）
  notes       String?

  @@index([pickupId])
}
