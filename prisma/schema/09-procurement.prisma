// ========== 供應商管理 ==========
model Supplier {
  id               String   @id @default(cuid())
  code             String   @unique
  name             String
  contactPerson    String?
  phone            String?
  email            String?
  address          String?
  taxId            String?
  paymentTerms     String?
  country          String? // 國家：TW/VN/ID/TH/CN
  capacity         String? // 月產能描述
  moq              Int? // 最小訂購量
  avgDefectRate    Decimal? @db.Decimal(5, 2) // 平均不良率 %
  leadTimeDays     Int? // 交期天數
  supplyCategories String? // 採購分類 (JSON array of PurchaseType values)
  supplyItems      String? // 供應品項描述
  notes            String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  purchaseOrders              PurchaseOrder[]
  priceHistory                SupplierPriceHistory[]
  productionOrders            ProductionOrder[]      @relation("FactoryProduction")
  paymentRecords              PaymentRecord[]
  qualityChecks               QualityCheck[]         @relation("QcSupplier")
  packagingMaterials          PackagingMaterial[]    @relation("MaterialSupplier")
  accountsPayable             AccountsPayable[]      @relation("SupplierAP")
  materialSuppliers           MaterialSupplier[]
  factoryTerms                FactoryMaterialTerm[]  @relation("FactoryTerms")
  factoryIncidents            FactoryIncident[]      @relation("FactoryIncidentFactory")
  materialShipmentsAsSupplier MaterialShipment[]     @relation("MaterialShipmentSupplier")
  materialShipmentsAsFactory  MaterialShipment[]     @relation("MaterialShipmentFactory")
  supplierInvoices            SupplierInvoice[]      @relation("SupplierInvoiceSupplier")
  productSuppliers            ProductSupplier[]
  inventoryLots               InventoryLot[]         @relation("LotSupplier")

  // ── P0-P1 新增關聯 ──────────────────────────────────
  productionReceipts ProductionReceipt[] @relation("ReceiptFactory")
  rfqSuppliers       RFQSupplier[]       @relation("RFQSupplierRef")

  // ── P3-2 進口費用 ────────────────────────────────────
  importProjects  ImportProject[]  @relation("ImportProjectSupplier")
  importCostItems ImportCostItem[] @relation("ImportCostItemSupplier")

  // ── P3-3 合約管理 ────────────────────────────────────
  contracts Contract[] @relation("ContractSupplier")

  // ── P3-5 固定資產 ────────────────────────────────────
  fixedAssets FixedAsset[] @relation("AssetSupplier")

  // ── 採購計畫 ────────────────────────────────────────
  purchasePlanItems PurchasePlanItem[] @relation("PurchasePlanSupplier")

  // ── 進貨退貨 ────────────────────────────────────────
  purchaseReturns PurchaseReturn[]

  // ── 沖帳作業 ────────────────────────────────────────
  settlements SettlementBatch[] @relation("SupplierSettlements")
}

// 歷史採購價格
model SupplierPriceHistory {
  id            String   @id @default(cuid())
  supplierId    String
  supplier      Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product? @relation(fields: [productId], references: [id])
  itemName      String // 品項名稱
  unitCost      Decimal  @db.Decimal(10, 2)
  currency      String   @default("TWD")
  effectiveDate DateTime
  notes         String?
  createdAt     DateTime @default(now())
}

// ========== 採購管理 ==========
model PurchaseOrder {
  id          String         @id @default(cuid())
  poNo        String         @unique
  supplierId  String
  supplier    Supplier       @relation(fields: [supplierId], references: [id])
  createdById String
  createdBy   User           @relation(fields: [createdById], references: [id])
  applicantId String? // 申請人（提出需求的業務/倉管）
  purchaserId String? // 採購經辦人
  status      PurchaseStatus @default(DRAFT)
  orderType   PurchaseType   @default(FINISHED_GOODS)

  // ── 基本資訊 ──────────────────────────────────────────
  purchaseDate       DateTime  @default(now()) // 採購日期
  expectedDate       DateTime? // 預計到貨日
  deliveryTerm       String? // 交貨條件：EXW / FOB / CIF / DAP
  paymentTerm        String? // 付款條件：T/T / L/C / 月結
  currency           String    @default("TWD")
  exchangeRate       Decimal?  @db.Decimal(8, 4) // 匯率（外幣→TWD）
  warehouse          String? // 收貨倉庫
  projectNo          String? // 專案號
  specVersion        String? // 規格版本
  inspectionCriteria String? // 驗收標準

  // ── 金額（4 層）──────────────────────────────────────
  subtotal        Decimal  @db.Decimal(12, 2) // 品項小計
  taxRate         Decimal? @db.Decimal(5, 2) // 稅率 %
  taxAmount       Decimal? @db.Decimal(12, 2) // 稅額
  freightCost     Decimal  @default(0) @db.Decimal(12, 2) // 運費
  otherCost       Decimal  @default(0) @db.Decimal(12, 2) // 其他費用
  totalAmount     Decimal  @db.Decimal(12, 2) // = subtotal + taxAmount + freightCost + otherCost
  paidAmount      Decimal  @default(0) @db.Decimal(12, 2)
  finalSettlement Decimal? @db.Decimal(12, 2) // 最終結算金額
  notes           String?

  // ── OEM / 工廠延伸欄位 ────────────────────────────────
  oemProjectNo              String?
  factory                   String? // 對應工廠名稱（文字，supplierId 為主 FK）
  sampleVersion             String?
  packagingVersion          String?
  productionBatch           String?
  inspectionRequirements    String?
  shippingLabelRequirements String?
  customNotes               String?

  // ── 生產時程（預計 + 實際）────────────────────────────
  plannedStartDate        DateTime? // 預計開工日
  plannedEndDate          DateTime? // 預計完工日
  actualStartDate         DateTime? // 實際開工日
  actualEndDate           DateTime? // 實際完工日
  packagingReadyDate      DateTime? // 包材到位日
  rawMaterialReadyDate    DateTime? // 原料到位日
  productionConfirmedDate DateTime? // 生產排程確認日
  factoryShipDate         DateTime? // 出廠日
  inspectionDate          DateTime? // 驗貨日
  supplementDate          DateTime? // 補料日

  // ── 品質/成本 ─────────────────────────────────────────
  defectRate           Decimal? @db.Decimal(5, 2)
  defectResponsibility String?
  lossRate             Decimal? @db.Decimal(5, 2)
  delayReason          String? // 延誤原因
  finalUnitCost        Decimal? @db.Decimal(10, 2) // 最終結算單價

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items             PurchaseOrderItem[]
  receipts          PurchaseReceipt[]
  inventoryLots     InventoryLot[]
  productionOrders  ProductionOrder[]
  seaFreights       SeaFreight[]
  payments          PaymentRecord[]
  qualityChecks     QualityCheck[]
  apRecords         AccountsPayable[]   @relation("PurchaseAP")
  supplierInvoices  SupplierInvoice[]   @relation("PurchaseSupplierInvoice")
  materialShipments MaterialShipment[]  @relation("PurchaseMaterialShipment")
  purchaseReturns   PurchaseReturn[]

  @@index([supplierId, status])
  @@index([status, createdAt(sort: Desc)])
  @@index([expectedDate])
}

// ========== 進貨退貨 ==========
model PurchaseReturn {
  id             String        @id @default(cuid())
  returnNo       String        @unique
  purchaseId     String
  purchase       PurchaseOrder @relation(fields: [purchaseId], references: [id])
  supplierId     String
  supplier       Supplier      @relation(fields: [supplierId], references: [id])
  returnType     ReturnType    @default(RETURN)
  reason         String?
  returnCategory String?
  status         ReturnStatus  @default(PENDING)
  requestDate    DateTime      @default(now())
  approvedById   String?
  approvedAt     DateTime?
  shippedDate    DateTime?
  debitNoteNo    String? // 扣款通知單號
  deductAmount   Decimal?      @db.Decimal(12, 2)
  deductStatus   String? // PENDING / DEDUCTED / REFUNDED
  notes          String?
  createdById    String
  createdBy      User          @relation("PurchaseReturnCreatedBy", fields: [createdById], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  items PurchaseReturnItem[]
}

model PurchaseReturnItem {
  id          String         @id @default(cuid())
  returnId    String
  returnOrder PurchaseReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  productId   String
  product     Product        @relation(fields: [productId], references: [id])
  quantity    Int
  unitCost    Decimal        @default(0) @db.Decimal(10, 2)
  subtotal    Decimal        @default(0) @db.Decimal(12, 2)
  batchNo     String?
  reason      String?
  condition   String?
  notes       String?
}

model PurchaseOrderItem {
  id          String             @id @default(cuid())
  orderId     String
  order       PurchaseOrder      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemType    String             @default("PRODUCT") // PRODUCT / MATERIAL
  productId   String?
  product     Product?           @relation(fields: [productId], references: [id])
  materialId  String? // 關聯包材
  material    PackagingMaterial? @relation(fields: [materialId], references: [id])
  // 快照
  skuSnap     String? // SKU 或料號快照
  nameSnap    String? // 品名快照
  specSnap    String? // 規格版本快照
  unit        String? // 單位
  quantity    Int
  receivedQty Int                @default(0)
  unitCost    Decimal            @db.Decimal(10, 2)
  currency    String? // 品項幣別（可不同於主單）
  subtotal    Decimal            @db.Decimal(12, 2)
  taxType     String? // 品項稅別
  notes       String?
}

model PurchaseReceipt {
  id          String        @id @default(cuid())
  receiptNo   String        @unique
  orderId     String
  order       PurchaseOrder @relation(fields: [orderId], references: [id])
  createdById String
  receiptDate DateTime      @default(now())
  notes       String?
  createdAt   DateTime      @default(now())

  items PurchaseReceiptItem[]
}

model PurchaseReceiptItem {
  id        String          @id @default(cuid())
  receiptId String
  receipt   PurchaseReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  productId String
  product   Product         @relation(fields: [productId], references: [id])
  quantity  Int
}

// ========== 包材追蹤 ==========
model PackagingMaterial {
  id               String    @id @default(cuid())
  code             String    @unique
  name             String
  materialType     String // WAISTBAND(腰貼) / BAG(袋) / BOX(箱) / LABEL(標籤) / OTHER
  supplierId       String?
  supplier         Supplier? @relation("MaterialSupplier", fields: [supplierId], references: [id])
  stockQty         Int       @default(0) // 庫存數量
  inTransitQty     Int       @default(0) // 在途數量
  sentToFactoryQty Int       @default(0) // 已送工廠數量
  wastageRate      Decimal?  @db.Decimal(5, 2) // 損耗率 %
  unit             String    @default("個")
  safetyStock      Int       @default(0)
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  purchaseItems         PurchaseOrderItem[]
  materialSuppliers     MaterialSupplier[]
  factoryTerms          FactoryMaterialTerm[]
  productBOMs           ProductBOM[]
  materialShipmentItems MaterialShipmentItem[]
}

model MaterialSupplier {
  id            String            @id @default(cuid())
  materialId    String
  material      PackagingMaterial @relation(fields: [materialId], references: [id])
  supplierId    String
  supplier      Supplier          @relation(fields: [supplierId], references: [id])
  unitPrice     Decimal           @db.Decimal(10, 4)
  currency      String            @default("USD")
  moq           Int?
  leadTimeDays  Int?
  paymentTerms  String?
  originCountry String?
  originCity    String?
  avgDefectRate Decimal?          @db.Decimal(5, 2)
  lastQcResult  String?
  isPrimary     Boolean           @default(false)
  isActive      Boolean           @default(true)
  notes         String?
  updatedAt     DateTime          @updatedAt

  @@unique([materialId, supplierId])
}

model FactoryMaterialTerm {
  id              String            @id @default(cuid())
  factoryId       String
  factory         Supplier          @relation("FactoryTerms", fields: [factoryId], references: [id])
  materialId      String
  material        PackagingMaterial @relation(fields: [materialId], references: [id])
  usagePerUnit    Decimal?          @db.Decimal(10, 4)
  usageUnit       String?
  wastageRate     Decimal?          @db.Decimal(5, 2)
  supplyMode      String            @default("BUYER")
  factoryPrice    Decimal?          @db.Decimal(10, 4)
  factoryCurrency String?
  specRequirement String?
  minGrade        String?
  notes           String?
  updatedAt       DateTime          @updatedAt

  @@unique([factoryId, materialId])
}

model MaterialShipment {
  id              String                 @id @default(cuid())
  shipmentNo      String                 @unique
  sourceType      String
  supplierId      String?
  supplier        Supplier?              @relation("MaterialShipmentSupplier", fields: [supplierId], references: [id])
  factoryId       String
  factory         Supplier               @relation("MaterialShipmentFactory", fields: [factoryId], references: [id])
  shippingMethod  String?
  carrier         String?
  trackingNo      String?
  originCountry   String?
  originPort      String?
  destCountry     String?
  destPort        String?
  shipDate        DateTime?
  etaFactory      DateTime?
  actualArrival   DateTime?
  status          String                 @default("PREPARING")
  freightCost     Decimal?               @db.Decimal(12, 2)
  currency        String                 @default("USD")
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder?         @relation("PurchaseMaterialShipment", fields: [purchaseOrderId], references: [id])
  notes           String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  items           MaterialShipmentItem[]
}

model MaterialShipmentItem {
  id          String            @id @default(cuid())
  shipmentId  String
  shipment    MaterialShipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  materialId  String
  material    PackagingMaterial @relation(fields: [materialId], references: [id])
  batchNo     String?
  quantity    Int
  unit        String?
  receivedQty Int?
  damageQty   Int?
  qcResult    String?
  notes       String?
}

model FactoryIncident {
  id                 String          @id @default(cuid())
  productionOrderId  String
  productionOrder    ProductionOrder @relation(fields: [productionOrderId], references: [id])
  factoryId          String?
  factory            Supplier?       @relation("FactoryIncidentFactory", fields: [factoryId], references: [id])
  incidentType       String
  severity           String          @default("MEDIUM")
  description        String
  occurredDate       DateTime
  affectedQty        Int?
  affectedBatchNo    String?
  delayDays          Int?
  responsibility     String?
  resolution         String?
  compensationAmount Decimal?        @db.Decimal(12, 2)
  creditNoteId       String?
  status             String          @default("OPEN")
  resolvedAt         DateTime?
  photos             Json?
  notes              String?
  createdById        String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}
