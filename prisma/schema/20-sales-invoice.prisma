model SalesInvoice {
  id              String             @id @default(cuid())
  invoiceNumber   String             @unique
  date            DateTime           @default(now())
  customerId      String
  salesPersonId   String
  handlerId       String
  warehouseId     String
  transactionType String             @default("TAX")
  currency        String             @default("TWD")
  receiverName    String?
  shippingAddress String?
  phone           String?
  shippingNote    String?
  departmentId    String?
  notes           String?
  subtotal        Decimal            @default(0) @db.Decimal(12, 2)
  taxAmount       Decimal            @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal            @default(0) @db.Decimal(12, 2)
  status          SalesInvoiceStatus @default(DRAFT)
  approvalStatus  ApprovalStatus     @default(PENDING)
  sourceOrderId   String?
  createdById     String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  eInvoices       EInvoice[]         @relation("InvoiceEInvoice")
  pickingOrders   PickingOrder[]     @relation("PickingFromInvoice")
  createdBy       User               @relation("SalesInvoiceCreatedBy", fields: [createdById], references: [id])
  customer        Customer           @relation(fields: [customerId], references: [id])
  handler         User               @relation("SalesInvoiceHandler", fields: [handlerId], references: [id])
  salesPerson     User               @relation("SalesInvoiceSalesPerson", fields: [salesPersonId], references: [id])
  sourceOrder     SalesOrder?        @relation("InvoiceFromOrder", fields: [sourceOrderId], references: [id])
  warehouse       Warehouse          @relation("SalesInvoiceWarehouse", fields: [warehouseId], references: [id])
  items           SalesInvoiceItem[]

  @@index([customerId, date])
  @@index([status, date])
  @@index([sourceOrderId])
}

model SalesInvoiceItem {
  id             String       @id @default(cuid())
  salesInvoiceId String
  productId      String
  productName    String
  specification  String?
  quantity       Decimal      @db.Decimal(10, 2)
  unit           String?
  unitPrice      Decimal      @db.Decimal(10, 2)
  unitPriceTax   Decimal      @db.Decimal(10, 2)
  subtotal       Decimal      @db.Decimal(12, 2)
  taxAmount      Decimal      @db.Decimal(12, 2)
  totalAmount    Decimal      @db.Decimal(12, 2)
  memo           String?
  serialNumber   String?
  product        Product      @relation("SalesInvoiceItemProduct", fields: [productId], references: [id])
  salesInvoice   SalesInvoice @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)

  @@index([salesInvoiceId])
}
