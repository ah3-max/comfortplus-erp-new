// ========== 銷貨單（Sales Invoice） ==========
// 流程：報價單(Quotation) → 訂貨單(SalesOrder) → 銷貨單(SalesInvoice) → 收款(Payment)

model SalesInvoice {
  id              String             @id @default(cuid())
  invoiceNumber   String             @unique  // 銷貨單單號（SI + YYYYMMDD + 流水號）
  date            DateTime           @default(now())
  customerId      String
  customer        Customer           @relation(fields: [customerId], references: [id])
  salesPersonId   String             // 業務人員
  salesPerson     User               @relation("SalesInvoiceSalesPerson", fields: [salesPersonId], references: [id])
  handlerId       String             // 承辦人
  handler         User               @relation("SalesInvoiceHandler", fields: [handlerId], references: [id])
  warehouseId     String             // 發貨倉庫
  warehouse       Warehouse          @relation("SalesInvoiceWarehouse", fields: [warehouseId], references: [id])
  transactionType String             @default("TAX") // TAX=營業稅 / OTHER=其他（寄庫）
  currency        String             @default("TWD")

  // 收貨資訊
  receiverName    String?
  shippingAddress String?
  phone           String?
  shippingNote    String?

  // 關聯
  departmentId    String?
  notes           String?

  // 金額
  subtotal        Decimal            @default(0) @db.Decimal(12, 2)  // 稅前合計
  taxAmount       Decimal            @default(0) @db.Decimal(12, 2)  // 營業稅合計
  totalAmount     Decimal            @default(0) @db.Decimal(12, 2)  // 含稅合計

  // 狀態
  status          SalesInvoiceStatus @default(DRAFT)
  approvalStatus  ApprovalStatus     @default(PENDING)

  // 來源單據
  sourceOrderId   String?            // 拋轉的訂貨單
  sourceOrder     SalesOrder?        @relation("InvoiceFromOrder", fields: [sourceOrderId], references: [id])

  // 明細
  items           SalesInvoiceItem[]

  // 關聯單據
  eInvoices       EInvoice[]             @relation("InvoiceEInvoice")
  pickingOrders   PickingOrder[]         @relation("PickingFromInvoice")

  createdById     String
  createdBy       User               @relation("SalesInvoiceCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([customerId, date])
  @@index([status, date])
  @@index([sourceOrderId])
}

model SalesInvoiceItem {
  id              String       @id @default(cuid())
  salesInvoiceId  String
  salesInvoice    SalesInvoice @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)
  productId       String
  product         Product      @relation("SalesInvoiceItemProduct", fields: [productId], references: [id])
  productName     String       // 品項名稱快照
  specification   String?      // 規格
  quantity        Decimal      @db.Decimal(10, 2)
  unit            String?
  unitPrice       Decimal      @db.Decimal(10, 2) // 單價（未稅）
  unitPriceTax    Decimal      @db.Decimal(10, 2) // 單價（含稅）
  subtotal        Decimal      @db.Decimal(12, 2) // 稅前價格
  taxAmount       Decimal      @db.Decimal(12, 2) // 營業稅
  totalAmount     Decimal      @db.Decimal(12, 2) // 銷貨金額（含稅）
  memo            String?
  serialNumber    String?      // 序號/批號

  @@index([salesInvoiceId])
}
