model EInvoice {
  id               String               @id @default(cuid())
  invoiceNumber    String               @unique
  date             DateTime             @default(now())
  salesInvoiceId   String?
  customerId       String
  customerName     String
  invoiceType      EInvoiceType
  subtotal         Decimal              @db.Decimal(12, 2)
  taxAmount        Decimal              @db.Decimal(12, 2)
  totalAmount      Decimal              @db.Decimal(12, 2)
  creditNoteNumber String?
  status           EInvoiceStatus       @default(CREATED)
  transmitStatus   TransmitStatus       @default(PENDING)
  transmittedAt    DateTime?
  buyerTaxId       String?
  buyerName        String?
  createdById      String
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  creditNoteAmount Decimal?             @db.Decimal(12, 2)
  creditNoteDate   DateTime?
  voidReason       String?
  voidedAt         DateTime?
  createdBy        User                 @relation("EInvoiceCreatedBy", fields: [createdById], references: [id])
  customer         Customer             @relation("CustomerEInvoice", fields: [customerId], references: [id])
  salesInvoice     SalesInvoice?        @relation("InvoiceEInvoice", fields: [salesInvoiceId], references: [id])
  turnkeyLogs      EInvoiceTurnkeyLog[] @relation("TurnkeyLogEInvoice")

  @@index([salesInvoiceId])
  @@index([customerId, date])
  @@index([status, transmitStatus])
}
