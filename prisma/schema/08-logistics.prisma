// ========== 物流商主檔 ==========
model LogisticsProvider {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  regions        String?  // 配送區域 (JSON array of strings)
  deliveryDays   Int?     // 配送時效（天）
  paymentTerms   String?  // 付款條件
  rateCard       String?  // 運價表（描述或 JSON）
  contactPerson  String?
  contactPhone   String?
  contactEmail   String?
  claimRules     String?  // 異常理賠規則
  notes          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  shipments Shipment[]
}

// ========== 車次管理（自有車隊） ==========
model DeliveryTrip {
  id          String             @id @default(cuid())
  tripNo      String             @unique
  vehicleId   String?
  vehicle     Vehicle?           @relation(fields: [vehicleId], references: [id])
  driverId    String?
  driver      Driver?            @relation("TripDriver", fields: [driverId], references: [id])
  routeId     String?
  route       DeliveryRoute?     @relation(fields: [routeId], references: [id])
  vehicleNo   String?            // 車牌（快捷欄位，無 Vehicle 時用）
  driverName  String?            // 司機姓名（快捷欄位）
  driverPhone String?
  region      String?
  tripDate    DateTime
  status      DeliveryTripStatus @default(PLANNED)
  totalFuelCost      Decimal?   @db.Decimal(10, 2)
  tollFee            Decimal?   @db.Decimal(10, 2)
  driverAllowance    Decimal?   @db.Decimal(10, 2)
  otherCost          Decimal?   @db.Decimal(10, 2)
  totalTripCost      Decimal?   @db.Decimal(10, 2)
  actualStops        Int?
  totalKm            Decimal?   @db.Decimal(8, 1)
  totalHours         Decimal?   @db.Decimal(4, 1)
  departureTime      DateTime?
  returnTime         DateTime?
  deliveredCount     Int?
  failedCount        Int?
  isEmptyReturn      Boolean    @default(false)
  emptyReturnReason  String?
  actualWeight       Decimal?   @db.Decimal(8, 2)
  loadRate           Decimal?   @db.Decimal(5, 2)
  routeStops         Json?
  routeMapUrl        String?
  driverAcceptedAt   DateTime?
  driverStartedAt    DateTime?
  driverCompletedAt  DateTime?
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  shipments   Shipment[]
}

// ========== 車輛主檔 ==========
model Vehicle {
  id          String   @id @default(cuid())
  plateNo     String   @unique  // 車牌
  vehicleType String?  // 3.5T / 5T / 11T
  maxWeight   Decimal? @db.Decimal(8, 2) // 載重（噸）
  maxVolume   Decimal? @db.Decimal(8, 2) // 容積（CBM）
  owner       String?  // 所屬單位
  isActive    Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trips       DeliveryTrip[]
  drivers     Driver[]
}

// ========== 司機主檔 ==========
model Driver {
  id          String   @id @default(cuid())
  name        String
  phone       String?
  vehicleId   String?
  vehicle     Vehicle? @relation(fields: [vehicleId], references: [id])
  serviceArea String?  // 服務區域
  isActive    Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trips       DeliveryTrip[] @relation("TripDriver")
}

// ========== 配送路線 ==========
model DeliveryRoute {
  id             String   @id @default(cuid())
  routeName      String
  region         String?  // 配送區域
  estimatedStops Int?     // 預估停點數
  estimatedKm    Decimal? @db.Decimal(8, 1) // 預估里程
  estimatedHours Decimal? @db.Decimal(4, 1) // 預估工時
  scheduledDate  DateTime?
  scheduledById  String?  // 排程人
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  trips          DeliveryTrip[]
}

// ========== 簽收管理 ==========
model ProofOfDelivery {
  id              String    @id @default(cuid())
  shipmentId      String
  shipment        Shipment  @relation(fields: [shipmentId], references: [id])
  signerName      String?   // 簽收人
  signedAt        DateTime? // 簽收時間
  photoUrl        String?   // 簽收照片
  anomalyNote     String?   // 異常註記
  deliveredAt     DateTime?
  gpsLat          Decimal?  @db.Decimal(10, 7)
  gpsLng          Decimal?  @db.Decimal(10, 7)
  customerNotified Boolean  @default(false)
  salesNotified    Boolean  @default(false)
  isCompleted     Boolean   @default(false)
  createdAt       DateTime  @default(now())
}

// ========== 退貨管理 ==========
model ReturnOrder {
  id              String       @id @default(cuid())
  returnNo        String       @unique
  orderId         String
  order           SalesOrder   @relation(fields: [orderId], references: [id])
  customerId      String
  customer        Customer     @relation(fields: [customerId], references: [id])
  returnType      ReturnType   @default(RETURN)
  reason          String?
  returnCategory  String?
  disposalMethod  String?
  responsibility  String?
  factoryClaimId  String?
  creditNoteId    String?
  affectsSalesKpi Boolean      @default(true)
  kpiExemptReason String?
  status          ReturnStatus @default(PENDING)
  requestDate     DateTime     @default(now())
  approvedById    String?
  approvedAt      DateTime?
  receivedDate    DateTime?    // 退貨收到日
  warehouseId     String?      // 退回倉庫
  refundAmount    Decimal?     @db.Decimal(12, 2)
  refundStatus    String?      // PENDING / REFUNDED / DEDUCTED
  notes           String?
  createdById     String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  items           ReturnOrderItem[]
  inboundRecords  InboundRecord[]
}

model ReturnOrderItem {
  id          String      @id @default(cuid())
  returnId    String
  returnOrder ReturnOrder @relation(fields: [returnId], references: [id], onDelete: Cascade)
  productId   String
  product     Product     @relation(fields: [productId], references: [id])
  quantity    Int
  batchNo     String?
  disposalResult String?
  qcResult    String?
  reason      String?     // 品項退貨原因
  condition   String?     // GOOD / DAMAGED / DEFECTIVE
  notes       String?
}

// ========== 出貨管理 ==========
model Shipment {
  id                   String             @id @default(cuid())
  shipmentNo           String             @unique
  orderId              String
  order                SalesOrder         @relation(fields: [orderId], references: [id])
  createdById          String
  createdBy            User               @relation(fields: [createdById], references: [id])
  status               ShipmentStatus     @default(PREPARING)

  // 物流資訊
  deliveryMethod       DeliveryMethod     @default(EXPRESS)
  logisticsProviderId  String?
  logisticsProvider    LogisticsProvider? @relation(fields: [logisticsProviderId], references: [id])
  tripId               String?
  trip                 DeliveryTrip?      @relation(fields: [tripId], references: [id])
  trackingNo           String?
  carrier              String?            // 舊欄位保留相容性

  // 出貨資訊
  warehouse            String             @default("MAIN")   // 出貨倉庫
  address              String?
  palletCount          Int?               // 棧板數
  boxCount             Int?               // 箱數
  weight               Decimal?           @db.Decimal(10, 3) // 重量 (kg)
  volume               String?            // 材積

  // 時間
  shipDate             DateTime?          // 出貨日
  expectedDeliveryDate DateTime?          // 預計到貨日
  deliveryDate         DateTime?          // 實際到貨日（已簽收）

  // 簽收 / 異常
  signStatus           SignStatus         @default(PENDING)
  anomalyStatus        AnomalyStatus      @default(NORMAL)
  anomalyNote          String?

  // 物流成本
  freightCost          Decimal?           @db.Decimal(10, 2)
  codFee               Decimal?           @db.Decimal(10, 2)
  insuranceFee         Decimal?           @db.Decimal(10, 2)
  surcharge            Decimal?           @db.Decimal(10, 2)
  totalDeliveryCost    Decimal?           @db.Decimal(10, 2)
  logisticsInvoiceNo   String?
  logisticsBillingRef  String?
  fuelCost             Decimal?           @db.Decimal(10, 2)
  driverAllowanceCost Decimal?           @db.Decimal(10, 2)
  tollFeeCost          Decimal?           @db.Decimal(10, 2)
  vehicleCost          Decimal?           @db.Decimal(10, 2)

  // 異常處理
  anomalyType          String?
  anomalyResolution    String?
  anomalyResolvedAt    DateTime?

  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  items              ShipmentItem[]
  proofOfDeliveries  ProofOfDelivery[]
}

model ShipmentItem {
  id         String   @id @default(cuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  batchNo    String?
  lotId      String?
  boxCount   Int?     // 此品項箱數
  notes      String?  // 備註（用於撿貨單說明）
}
